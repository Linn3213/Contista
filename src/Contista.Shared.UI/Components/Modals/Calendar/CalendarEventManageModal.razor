    new ReminderPreset("15", "15 " + Loc.GetOr("Common_MinutesShort", "min")),
    new ReminderPreset("30", "30 " + Loc.GetOr("Common_MinutesShort", "min")),
    new ReminderPreset("60", "60 " + Loc.GetOr("Common_MinutesShort", "min")),
