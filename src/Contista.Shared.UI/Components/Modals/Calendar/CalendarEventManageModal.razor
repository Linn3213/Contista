    private string GetPresetLabel(string value)
    {
        if (value == "custom")
        {
            var mins = Model.Reminders is { Count: > 0 } ? Model.Reminders[0].MinutesBeforeStart : 0;
            return $"{Loc.GetOr("Common_Custom", "Custom")}: {mins} min";
        }

        return value == "0"
            ? Loc.GetOr("Common_Reminder_AtStart", "At start")
            : $"{value} min";
    }

    private void SetReminderPreset(string value)
    {
        _reminderPreset = string.IsNullOrWhiteSpace(value) ? "30" : value;

        EnsureSingleReminder();
        var r = Model.Reminders![0];

        if (_reminderPreset != "custom")
        {
            if (int.TryParse(_reminderPreset, out var mins))
                r.MinutesBeforeStart = Math.Max(0, mins);
        }

        StateHasChanged();
    }

    private bool ChecklistEnabled
    {
        get => Model.Checklist is { Count: > 0 };
        set
        {
            if (value)
            {
                Model.Checklist ??= new List<ChecklistItemDto>();

                if (Model.Checklist.Count == 0)
                {
                    Model.Checklist.Add(new ChecklistItemDto
                    {
                        Id = null,
                        Text = "",
                        Done = false,
                        Order = 0
                    });
                }
            }
            else
            {
                Model.Checklist = null;
            }
        }
    }

    protected override void OnParametersSet()
    {
        Calendars ??= new();

        var openingNow = IsOpen && !_wasOpen;
        var eventChanged = IsOpen && IsEdit && !string.Equals(_lastEventId, ExistingEvent?.EventId, StringComparison.Ordinal);

        if (openingNow || eventChanged)
        {
            Init();
            _lastEventId = ExistingEvent?.EventId;
        }

        _wasOpen = IsOpen;
    }

    protected override async Task OnInitializedAsync()
    {
        _reminderChannelsFeatureEnabled = await Features.CanAsync(FeatureKey.CalendarRemindersChannels, CancellationToken.None);
        _reminderChannelsSelectionEnabled = await Features.CanAsync(FeatureKey.CalendarRemindersChannelsEnable, CancellationToken.None);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !_scrollLocked)
        {
            _scrollLocked = true;

            await JS.InvokeVoidAsync("contista.lockScroll.lock");
            TakeSnapshot();

            // fokus så ESC funkar direkt
            await _modalRef.FocusAsync();
        }

        if (!IsOpen && _scrollLocked)
        {
            _scrollLocked = false;
            await JS.InvokeVoidAsync("contista.lockScroll.unlock");
        }
    }

    private void TakeSnapshot()
    {
        _initialSnapshot = MakeSnapshot(Model, SelectedCalendarId, _recurrenceEndMode, _recurrenceUntilLocalText);
    }

    private static string MakeSnapshot(
    CalendarEventDto m,
    string? selectedCalendarId,
    string recurrenceEndMode,
    string recurrenceUntilLocalText)
    {
        // Viktigt: inkludera bara saker som påverkar “osparat”
        // (och gör checklist/reminders/recurrence null-safe)
        var snapshot = new
        {
            m.Title,
            m.Description,
            m.Location,
            m.Type,
            CalendarId = selectedCalendarId ?? m.CalendarId,

            m.IsAllDay,
            m.StartUtc,
            m.EndUtc,

            m.Availability,
            m.Visibility,

            Reminders = (m.Reminders ?? new()).Select(r => new { r.Channel, r.MinutesBeforeStart }).ToList(),

            Recurrence = m.Recurrence is null ? null : new
            {
                m.Recurrence.Frequency,
                m.Recurrence.Interval,
                ByWeekDays = (m.Recurrence.ByWeekDays ?? new()).OrderBy(x => x).ToList(),
                m.Recurrence.UntilUtc,
                m.Recurrence.Count,
                recurrenceEndMode,
                recurrenceUntilLocalText
            },

            Checklist = (m.Checklist ?? new()).Select(c => new { c.Text, c.Done, c.Order }).ToList()
        };

        return System.Text.Json.JsonSerializer.Serialize(snapshot);
    }

    private bool IsDirty()
    {
        var now = MakeSnapshot(Model, SelectedCalendarId, _recurrenceEndMode, _recurrenceUntilLocalText);
        return !string.Equals(now, _initialSnapshot, StringComparison.Ordinal);
    }

    private async Task RequestCloseAsync()
    {
        if (!IsDirty())
        {
            await CloseAsync();
            return;
        }

        var discard = await AskDiscardAsync();
        if (discard)
            await CloseAsync();
    }

    private Task<bool> AskDiscardAsync()
    {
        _confirmTcs = new TaskCompletionSource<bool>();
        _ = _confirmClose!.ShowAsync(); // visar modalen
        return _confirmTcs.Task;
    }

    private Task OnConfirmCloseClosed(bool confirmed)
    {
        _confirmTcs?.TrySetResult(confirmed);
        return Task.CompletedTask;
    }

    private void Init()
    {
        if (ExistingEvent is not null)
        {
            Model = new CalendarEventDto
            {
                EventId = ExistingEvent.EventId,
                CalendarId = ExistingEvent.CalendarId,
                CreatedById = ExistingEvent.CreatedById,

                Type = ExistingEvent.Type,
                Title = ExistingEvent.Title ?? "",
                Description = ExistingEvent.Description ?? "",
                Location = ExistingEvent.Location,

                StartUtc = ExistingEvent.StartUtc,
                EndUtc = ExistingEvent.EndUtc,
                IsAllDay = ExistingEvent.IsAllDay,

                OccurrenceOverrideSeriesId = ExistingEvent.OccurrenceOverrideSeriesId,
                OriginalStartUtc = ExistingEvent.OriginalStartUtc,
                IsOccurrenceOverride = ExistingEvent.IsOccurrenceOverride,
                IsOccurrenceCancelled = ExistingEvent.IsOccurrenceCancelled,

                Availability = ExistingEvent.Availability,
                Visibility = ExistingEvent.Visibility,

                Reminders = ExistingEvent.Reminders?.Select(r => new ReminderDto
                {
                    Channel = r.Channel,
                    MinutesBeforeStart = r.MinutesBeforeStart
                }).ToList() ?? new(),

                Recurrence = ExistingEvent.Recurrence is null ? null : new RecurrenceDto
                {
                    Frequency = ExistingEvent.Recurrence.Frequency,
                    Interval = ExistingEvent.Recurrence.Interval,
                    ByWeekDays = ExistingEvent.Recurrence.ByWeekDays?.ToList() ?? new(),
                    UntilUtc = ExistingEvent.Recurrence.UntilUtc,
                    Count = ExistingEvent.Recurrence.Count,
                    SeriesId = ExistingEvent.Recurrence.SeriesId
                },

                IsDone = ExistingEvent.IsDone,
                Checklist = ExistingEvent.Checklist?.Select(c => new ChecklistItemDto
                {
                    Id = c.Id,
                    Text = c.Text,
                    Done = c.Done,
                    Order = c.Order
                }).ToList(), // kan bli null

                ContentPostId = ExistingEvent.ContentPostId,

                HasConflict = ExistingEvent.HasConflict,
                ConflictWithEventIds = ExistingEvent.ConflictWithEventIds?.ToList() ?? new(),
                ConflictAcknowledgedByUserIds = ExistingEvent.ConflictAcknowledgedByUserIds?.ToList() ?? new(),

                CreatedAtUtc = ExistingEvent.CreatedAtUtc,
                UpdatedAtUtc = ExistingEvent.UpdatedAtUtc,
                LastMutationId = ExistingEvent.LastMutationId
            };

            if (Model.Checklist is { Count: 0 })
                Model.Checklist = null;

            SelectedCalendarId = ExistingEvent.CalendarId;

            _startLocal = (Model.StartUtc == default ? DefaultStartLocal : Model.StartUtc.ToLocalTime());
            _endLocal = (Model.EndUtc == default ? DefaultEndLocal : Model.EndUtc.ToLocalTime());
        }
        else
        {
            Model = new CalendarEventDto
            {
                Title = "",
                Description = "",
                Location = "",
                Type = CalendarEventType.Event,
                Availability = CalendarAvailability.Busy,
                Visibility = CalendarVisibility.Details,
                Reminders = new(),
                Checklist = null
            };

            _startLocal = DefaultStartLocal;
            _endLocal = DefaultEndLocal;
        }

        if (_endLocal <= _startLocal)
            _endLocal = _startLocal.AddMinutes(30);

        _duration = _endLocal - _startLocal;
        if (_duration < TimeSpan.FromMinutes(1))
            _duration = TimeSpan.FromMinutes(30);

        _endTouched = false;

        SelectedCalendarId =
            SelectedCalendarId
            ?? DefaultCalendarId
            ?? Calendars.FirstOrDefault(c => c.IsPrimary)?.CalendarId
            ?? Calendars.FirstOrDefault()?.CalendarId;

        if (!string.IsNullOrWhiteSpace(SelectedCalendarId))
            Model.CalendarId = SelectedCalendarId;

        if (Model.IsAllDay)
        {
            _startLocal = _startLocal.Date;

            var endDateExclusive = _endLocal.Date;
            if (endDateExclusive <= _startLocal.Date)
                endDateExclusive = _startLocal.Date.AddDays(1);

            _endLocal = endDateExclusive;
            _endTouched = true;
            _duration = _endLocal - _startLocal;
        }

        _startText = ToLocalText(_startLocal);
        _endText = ToLocalText(_endLocal);

        _startDateText = ToLocalDateText(_startLocal.Date);
        _endDateText = ToLocalDateText(_endLocal.Date.AddDays(-1));
        _allDayDays = Math.Max(1, (_endLocal.Date - _startLocal.Date).Days);

        SyncModelTimesFromLocals();

        InitRecurrenceUiFromModel();
        NormalizeChecklistOrder();

        if (RemindersEnabled)
            EnsureSingleReminder();
        
        NormalizeReminders();

        // Synka preset-dropdown från model
        if (Model.Reminders is { Count: > 0 })
        {
            var mins = Model.Reminders[0].MinutesBeforeStart;
            _reminderPreset = mins switch
            {
                0 => "0",
                5 => "5",
                10 => "10",
                15 => "15",
                30 => "30",
                60 => "60",
                120 => "120",
                _ => "custom"
            };
        }
        else
        {
            _reminderPreset = "30";
        }
    }

    private void EnsureSingleReminder()
    {
        Model.Reminders ??= new();

        if (Model.Reminders.Count == 0)
        {
            Model.Reminders.Add(new ReminderDto
            {
                Channel = ReminderChannel.InApp,
                MinutesBeforeStart = 30
            });
        }
        else if (Model.Reminders.Count > 1)
        {
            Model.Reminders = new List<ReminderDto> { Model.Reminders[0] };
        }
    }

    private void RemoveOnlyReminder()
    {
        Model.Reminders = new();
        StateHasChanged();
    }

    private void OnFirstChecklistTextInput(ChangeEventArgs e)
    {
        // Om användaren börjar skriva när listan är tom: skapa första item automatiskt
        var text = e?.Value?.ToString() ?? "";
        if (Model.Checklist is null) Model.Checklist = new();
        if (Model.Checklist.Count == 0)
        {
            Model.Checklist.Add(new ChecklistItemDto { Text = text, Done = false, Order = 0 });
        }
        else
        {
            Model.Checklist[0].Text = text;
        }
    }

    private void InitRecurrenceUiFromModel()
    {
        if (Model.Recurrence is null)
        {
            _recurrenceEndMode = "none";
            _recurrenceUntilLocalText = "";
            return;
        }

        if (Model.Recurrence.Count.HasValue)
        {
            _recurrenceEndMode = "count";
            _recurrenceUntilLocalText = "";
            return;
        }

        var until = NormalizeUntil(Model.Recurrence.UntilUtc);

        if (until.HasValue)
        {
            _recurrenceEndMode = "until";
            var local = until.Value.ToLocalTime().Date;
            _recurrenceUntilLocalText = local.ToString("yyyy-MM-dd", Invariant);
            return;
        }

        // ✅ här hamnar default(0001-01-01) => none
        _recurrenceEndMode = "none";
        _recurrenceUntilLocalText = "";
        Model.Recurrence.UntilUtc = null; 
    }

    private static bool TryParseLocal(string s, out DateTime local)
        => DateTime.TryParseExact(s, DtFormats, Invariant, DateTimeStyles.None, out local);

    private static string ToLocalText(DateTime local)
        => local.ToString("yyyy-MM-ddTHH:mm", Invariant);

    private static string ToLocalDateText(DateTime localDate)
        => localDate.ToString("yyyy-MM-dd", Invariant);

    private static bool TryParseLocalDate(string s, out DateTime localDate)
        => DateTime.TryParseExact(s, "yyyy-MM-dd", Invariant, DateTimeStyles.None, out localDate);

    private void OnStartChanged(ChangeEventArgs e)
    {
        var s = e.Value?.ToString() ?? "";
        _startText = s;

        if (!TryParseLocal(s, out var dt))
            return;

        _startLocal = dt;

        if (!_endTouched)
        {
            _endLocal = _startLocal + _duration;
        }
        else if (_endLocal < _startLocal)
        {
            _endLocal = _startLocal.AddMinutes(30);
        }

        _endText = ToLocalText(_endLocal);
        SyncModelTimesFromLocals();
    }

    private void OnEndChanged(ChangeEventArgs e)
    {
        var s = e.Value?.ToString() ?? "";
        _endText = s;
        _endTouched = true;

        if (!TryParseLocal(s, out var dt))
            return;

        _endLocal = dt;

        if (_endLocal < _startLocal)
            _endLocal = _startLocal.AddMinutes(30);

        _duration = _endLocal - _startLocal;
        if (_duration < TimeSpan.FromMinutes(1))
            _duration = TimeSpan.FromMinutes(30);

        _endText = ToLocalText(_endLocal);
        SyncModelTimesFromLocals();
    }

    private void OnStartDateChanged(ChangeEventArgs e)
    {
        var s = e.Value?.ToString() ?? "";
        _startDateText = s;

        if (!TryParseLocalDate(s, out var date))
            return;

        _startLocal = date.Date;

        if (_allDayDays < 1) _allDayDays = 1;
        _endLocal = _startLocal.AddDays(_allDayDays);

        _endDateText = ToLocalDateText(_endLocal.Date.AddDays(-1));

        _startText = ToLocalText(_startLocal);
        _endText = ToLocalText(_endLocal);

        SyncModelTimesFromLocals();
    }

    private void OnEndDateChanged(ChangeEventArgs e)
    {
        var s = e.Value?.ToString() ?? "";
        _endDateText = s;

        if (!TryParseLocalDate(s, out var endInclusive))
            return;

        var endExclusive = endInclusive.Date.AddDays(1);

        if (endExclusive <= _startLocal.Date)
            endExclusive = _startLocal.Date.AddDays(1);

        _endLocal = endExclusive;
        _allDayDays = Math.Max(1, (_endLocal.Date - _startLocal.Date).Days);

        _startText = ToLocalText(_startLocal);
        _endText = ToLocalText(_endLocal);

        SyncModelTimesFromLocals();
    }

    private void SyncModelTimesFromLocals()
    {
        Model.StartUtc = DateTime.SpecifyKind(_startLocal, DateTimeKind.Local).ToUniversalTime();
        Model.EndUtc = DateTime.SpecifyKind(_endLocal, DateTimeKind.Local).ToUniversalTime();
    }

    private bool IsAllDay
    {
        get => Model.IsAllDay;
        set
        {
            Model.IsAllDay = value;

            if (value)
            {
                var startDate = _startLocal.Date;
                var endDate = _endLocal.Date;

                _allDayDays = Math.Max(1, (endDate - startDate).Days);
                _startLocal = startDate;
                _endLocal = _startLocal.AddDays(_allDayDays);

                _endTouched = true;
                _duration = _endLocal - _startLocal;

                _startDateText = ToLocalDateText(_startLocal.Date);
                _endDateText = ToLocalDateText(_endLocal.Date.AddDays(-1));
            }
            else
            {
                if (_endLocal <= _startLocal)
                    _endLocal = _startLocal.AddMinutes(30);

                _endTouched = false;
                _duration = _endLocal - _startLocal;
                if (_duration < TimeSpan.FromMinutes(1))
                    _duration = TimeSpan.FromMinutes(30);

                _startDateText = ToLocalDateText(_startLocal.Date);
                _endDateText = ToLocalDateText(_endLocal.Date.AddDays(-1));
                _allDayDays = Math.Max(1, (_endLocal.Date - _startLocal.Date).Days);
            }

            _startText = ToLocalText(_startLocal);
            _endText = ToLocalText(_endLocal);

            SyncModelTimesFromLocals();
        }
    }

    private async Task CloseAsync()
    {
        _wasOpen = false;
        _lastEventId = null;

        IsOpen = false;
        ExistingEvent = null;
        Model = new CalendarEventDto();

        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task DeleteAsync()
    {
        if (ExistingEvent is null) return;
        await OnDelete.InvokeAsync(ExistingEvent);
        await CloseAsync();
    }

    private async Task SaveAsync()
    {
        SyncModelTimesFromLocals();

        if (string.IsNullOrWhiteSpace(Model.Title))
            Model.Title = Loc.GetOr("Common_Actions_Untitled", "Untitled");

        if (Model.EndUtc <= Model.StartUtc)
        {
            _endLocal = _startLocal.AddMinutes(30);
            _endText = ToLocalText(_endLocal);
            SyncModelTimesFromLocals();
        }

        if (!string.IsNullOrWhiteSpace(SelectedCalendarId))
            Model.CalendarId = SelectedCalendarId;

        NormalizeRecurrence();
        NormalizeChecklistOrder();
        NormalizeReminders();

        if (IsEdit && ExistingEvent is not null)
        {
            Model.CreatedById = ExistingEvent.CreatedById;
            Model.CreatedAtUtc = ExistingEvent.CreatedAtUtc;
        }

        await OnSave.InvokeAsync(Model);
        TakeSnapshot();
        await CloseAsync();
    }

    private CalendarDto? GetSelectedCalendar()
    {
        var id = SelectedCalendarId ?? Model.CalendarId;
        if (string.IsNullOrWhiteSpace(id)) return null;

        return Calendars?.FirstOrDefault(c =>
            string.Equals(c.CalendarId, id, StringComparison.Ordinal));
    }

    private string GetSelectedCalendarLabel()
    {
        var cal = GetSelectedCalendar();
        if (cal is null) return Loc.GetOr("Common_None", "None");

        return cal.Name + (cal.IsPrimary ? $" ({Loc.GetOr("Common_Calendars_Primary", "Primary")})" : "");
    }

    private void SelectCalendar(string? calendarId)
    {
        if (string.IsNullOrWhiteSpace(calendarId))
            return;

        SelectedCalendarId = calendarId;
        Model.CalendarId = calendarId;
    }

    private string ResolveHex(string? calendarId)
    {
        if (CalendarIdToHex is null)
            return "#2B2622";

        var hex = CalendarIdToHex(calendarId);
        return string.IsNullOrWhiteSpace(hex) ? "#2B2622" : hex;
    }

    // -------------------------
    // Reminders helpers
    // -------------------------
    private void NormalizeReminders()
    {
        if (Model.Reminders is null) return;

        if (Model.Reminders.Count > 1)
            Model.Reminders = new List<ReminderDto> { Model.Reminders[0] };

        foreach (var r in Model.Reminders)
        {
            // ✅ om inte "enable" är på -> tvinga InApp
            if (!CanSelectReminderChannel)
                r.Channel = ReminderChannel.InApp;

            if (r.MinutesBeforeStart < 0) r.MinutesBeforeStart = 0;
        }
    }

    // -------------------------
    // Recurrence helpers
    // -------------------------
    private void ToggleRecurrence(ChangeEventArgs e)
    {
        var enabled = e?.Value is bool b && b;

        if (!enabled)
        {
            Model.Recurrence = null;
            _recurrenceEndMode = "none";
            _recurrenceUntilLocalText = "";
            return;
        }

        Model.Recurrence ??= new RecurrenceDto
        {
            Frequency = RecurrenceFrequency.Weekly,
            Interval = 1,
            ByWeekDays = new List<DayOfWeek>(),
            SeriesId = Guid.NewGuid().ToString("N")
        };

        InitRecurrenceUiFromModel();
    }

    private void ToggleWeekday(DayOfWeek d)
    {
        Model.Recurrence ??= new RecurrenceDto
        {
            Frequency = RecurrenceFrequency.Weekly,
            Interval = 1,
            ByWeekDays = new List<DayOfWeek>()
        };

        if (Model.Recurrence.ByWeekDays.Contains(d))
            Model.Recurrence.ByWeekDays.Remove(d);
        else
            Model.Recurrence.ByWeekDays.Add(d);
    }

    private void OnRecurrenceEndModeChanged()
    {
        if (Model.Recurrence is null)
            return;

        if (_recurrenceEndMode == "none")
        {
            Model.Recurrence.UntilUtc = null;
            Model.Recurrence.Count = null;
            _recurrenceUntilLocalText = "";
        }
        else if (_recurrenceEndMode == "until")
        {
            Model.Recurrence.Count = null;

            // ✅ om fältet är tomt eller "0001-01-01" => behandla som none
            if (string.IsNullOrWhiteSpace(_recurrenceUntilLocalText))
            {
                _recurrenceEndMode = "none";
                Model.Recurrence.UntilUtc = null;
            }
        }
        else if (_recurrenceEndMode == "count")
        {
            Model.Recurrence.UntilUtc = null;
            _recurrenceUntilLocalText = "";
            if (Model.Recurrence.Count is null or < 1) Model.Recurrence.Count = 1;
        }
    }

    private void OnRecurrenceUntilChanged(ChangeEventArgs e)
    {
        _recurrenceUntilLocalText = e?.Value?.ToString() ?? "";

        if (Model.Recurrence is null)
            return;

        if (DateTime.TryParseExact(_recurrenceUntilLocalText, "yyyy-MM-dd", Invariant, DateTimeStyles.None, out var localDate))
        {
            var localEnd = localDate.Date.AddDays(1).AddSeconds(-1);
            Model.Recurrence.UntilUtc = DateTime.SpecifyKind(localEnd, DateTimeKind.Local).ToUniversalTime();
        }
        else
        {
            Model.Recurrence.UntilUtc = null;
        }
    }

    private void NormalizeRecurrence()
    {
        if (Model.Recurrence is null)
            return;

        if (Model.Recurrence.Interval < 1)
            Model.Recurrence.Interval = 1;

        Model.Recurrence.ByWeekDays ??= new List<DayOfWeek>();

        if (string.IsNullOrWhiteSpace(Model.Recurrence.SeriesId))
            Model.Recurrence.SeriesId = Guid.NewGuid().ToString("N");

        // ✅ ByWeekDays är endast relevant för Weekly
        if (Model.Recurrence.Frequency != RecurrenceFrequency.Weekly)
        {
            Model.Recurrence.ByWeekDays.Clear();
        }
        else
        {
            // ✅ Weekly: om användaren inte valt dagar -> default = startdagen
            if (Model.Recurrence.ByWeekDays.Count == 0)
            {
                var startDow = _startLocal.DayOfWeek;
                Model.Recurrence.ByWeekDays.Add(startDow);
            }

            Model.Recurrence.ByWeekDays = Model.Recurrence.ByWeekDays
                .Distinct()
                .OrderBy(d => d == DayOfWeek.Sunday ? 7 : (int)d)
                .ToList();
        }

        if (_recurrenceEndMode == "none")
        {
            Model.Recurrence.UntilUtc = null;
            Model.Recurrence.Count = null;
        }
        else if (_recurrenceEndMode == "until")
        {
            Model.Recurrence.Count = null;
        }
        else if (_recurrenceEndMode == "count")
        {
            Model.Recurrence.UntilUtc = null;
            if (Model.Recurrence.Count is < 1) Model.Recurrence.Count = 1;
        }
    }

    // -------------------------
    // Checklist helpers
    // -------------------------
    private void AddChecklistItem()
    {
        Model.Checklist ??= new();
        Model.Checklist.Add(new ChecklistItemDto
        {
            Id = null,
            Text = "",
            Done = false,
            Order = Model.Checklist.Count
        });
        NormalizeChecklistOrder();
        StateHasChanged();
    }

    private void RemoveChecklistItem(ChecklistItemDto item)
    {
        if (Model.Checklist is null) return;

        Model.Checklist.Remove(item);

        if (Model.Checklist.Count == 0)
            Model.Checklist = null; // valfritt: auto-stäng checklist

        NormalizeChecklistOrder();
        StateHasChanged();
    }

    private void NormalizeChecklistOrder()
    {
        if (Model.Checklist is null) return;

        for (var i = 0; i < Model.Checklist.Count; i++)
            Model.Checklist[i].Order = i;
    }

    // -------------------------
    // Dropdown setters (forces rerender)
    // -------------------------
    private void SetType(CalendarEventType type) { Model.Type = type; StateHasChanged(); }
    private void SetAvailability(CalendarAvailability a) { Model.Availability = a; StateHasChanged(); }
    private void SetVisibility(CalendarVisibility v) { Model.Visibility = v; StateHasChanged(); }

    private void SetRecurrenceFrequency(RecurrenceFrequency f)
    {
        if (Model.Recurrence is null) return;

        Model.Recurrence.Frequency = f;

        if (f != RecurrenceFrequency.Weekly)
            Model.Recurrence.ByWeekDays?.Clear();

        StateHasChanged();
    }

    private void SetReminderChannel(int index, ReminderChannel ch)
    {
        if (Model.Reminders is null) return;
        if (index < 0 || index >= Model.Reminders.Count) return;

        Model.Reminders[index].Channel = ch;
        StateHasChanged();
    }

    private sealed record EndModeOption(string Value, string Label);

    private IEnumerable<EndModeOption> RecurrenceEndModes => new[]
    {
        new EndModeOption("none",  Loc.GetOr("Common_None", "None")),
        new EndModeOption("until", Loc.GetOr("Common_Until", "Until")),
        new EndModeOption("count", Loc.GetOr("Common_Count", "Count")),
    };

    private void SetRecurrenceEndMode(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            value = "none";

        if (!string.Equals(_recurrenceEndMode, value, StringComparison.Ordinal))
        {
            _recurrenceEndMode = value;
            OnRecurrenceEndModeChanged();
            StateHasChanged();
        }
    }

