    private string GetLocationMapEmbedUrl(string? location)
    {
        var clean = CalendarLocationHelper.Clean(location);
        if (string.IsNullOrWhiteSpace(clean))
            return string.Empty;

        return $"https://www.google.com/maps?q={Uri.EscapeDataString(clean)}&output=embed";
    }

    private static DateTime? NormalizeUntil(DateTime? untilUtc)
    {
        if (!untilUtc.HasValue) return null;

        var u = untilUtc.Value;

        // Firestore/DTO kan ge default istället för null
        if (u == default || u.Year < 1900) return null;

        return DateTime.SpecifyKind(u, DateTimeKind.Utc);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            await CloseAsync();
    }
    

    private bool IsOccurrenceEdit =>
    ExistingEvent is not null
    && ExistingEvent.Recurrence is null
    && !string.IsNullOrWhiteSpace(ExistingEvent.OccurrenceOverrideSeriesId)
    && ExistingEvent.OriginalStartUtc is not null;

    // (valfritt) även blockera om Model råkar bära dessa flags
    private bool IsOccurrenceEditFromModel =>
        !string.IsNullOrWhiteSpace(Model.OccurrenceOverrideSeriesId)
        && Model.OriginalStartUtc is not null;
