@* CalendarEventManageModal.razor *@
@using Contista.Shared.Core.DTO.Calendar
@using Contista.Shared.Core.Interfaces.Auth
@using Contista.Shared.Core.Models.Auth
@using System.Globalization
@using Contista.Shared.Core.Models.Calendar
@using Contista.Shared.UI.Components.Common
@using Contista.Shared.UI.Utils
@inject IJSRuntime JS
@inject IFeatureAccessService Features

@if (IsOpen)
{
    <div class="cal-modalOverlay">
        <div class="cal-modal cal-eventModal" tabindex="0"
             @ref="_modalRef"
             @onkeydown="HandleKeyDown"
             @onclick:stopPropagation="true">
            <div class="cal-modalHeader">
                <div>
                    <div class="cal-modalTitle">
                        @(IsEdit ? Loc.GetOr("Page_CalendarEventModal_EditTitle", "Edit event")
                                            : Loc.GetOr("Page_CalendarEventModal_AddTitle", "Add event"))
                    </div>
                    <div class="cal-modalSub">
                        @(IsEdit ? Loc.GetOr("Page_CalendarEventModal_EditSub", "Edit event / task / meeting")
                                            : Loc.GetOr("Page_CalendarEventModal_AddSub", "Create event / task / meeting"))
                    </div>
                    @if (IsOccurrenceEdit)
                    {
                        <div class="text-muted" style="font-size: var(--text-sm);">
                            @Loc.GetOr("Page_CalendarEventModal_EditThisEvent", "This instance only (deviation in the series)")
                        </div>
                    }
                    else if (HasRecurrence)
                    {
                        <div class="text-muted" style="font-size: var(--text-sm);">
                            @Loc.GetOr("Page_CalendarEventModal_EditWholeEvent", "The entire series")
                        </div>
                    }
                </div>

                <button type="button"
                        class="cal-modalClose"
                        @onclick="RequestCloseAsync"
                        aria-label="@Loc.GetOr("Common_Actions_Close", "Close")">
                    <i class="bi bi-x"></i>
                </button>
            </div>

            <div class="cal-modalBody">

                @* Title *@
                <div class="cal-formRow">
                    <label class="cal-label">@Loc.GetOr("Page_CalendarQuickAddModal_Title_Label", "Title")</label>
                    <input class="cal-input" @bind="Model.Title" />
                </div>

                @* Type & Calendar picker *@
                <div class="cal-formRow cal-grid2 cal-grid2-collapse">
                    <div class="cal-field cal-select">
                        <label class="cal-label">@Loc.GetOr("Page_CalendarQuickAddModal_Type_Label", "Type")</label>

                        <div class="dropdown">
                            <button type="button"
                                    class="cal-input cal-selectBtn dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                @GetTypeLabel(Model.Type)
                            </button>

                            <ul class="dropdown-menu cal-selectMenu">
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetType(CalendarEventType.Event)">
                                        @GetTypeLabel(CalendarEventType.Event)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetType(CalendarEventType.Meeting)">
                                        @GetTypeLabel(CalendarEventType.Meeting)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetType(CalendarEventType.Task)">
                                        @GetTypeLabel(CalendarEventType.Task)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetType(CalendarEventType.Checklist)">
                                        @GetTypeLabel(CalendarEventType.Checklist)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetType(CalendarEventType.Dnd)">
                                        @GetTypeLabel(CalendarEventType.Dnd)
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>

                    @if (HasManyCalendars)
                    {
                        <div class="cal-field cal-select">
                            <label class="cal-label">@Loc.GetOr("Page_CalendarQuickAddModal_Calendar_Label", "Calendar")</label>

                            <div class="dropdown">
                                <button type="button"
                                        class="cal-input cal-selectBtn dropdown-toggle"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">

                                    @{
                                        var selected = GetSelectedCalendar();
                                        var hex = ResolveHex(selected?.CalendarId);
                                    }

                                    <span class="cal-colorLeft">
                                        <span class="cal-colorSwatch" style="background:@hex"></span>
                                        <span class="cal-colorLabel text-truncate">@GetSelectedCalendarLabel()</span>
                                    </span>
                                </button>

                                <ul class="dropdown-menu cal-selectMenu">
                                    @foreach (var cal in Calendars.OrderByDescending(x => x.IsPrimary).ThenBy(x => x.Name))
                                    {
                                        var isSelected = string.Equals(cal.CalendarId, SelectedCalendarId, StringComparison.Ordinal);
                                        var resHex = ResolveHex(cal.CalendarId);

                                        <li>
                                            <button type="button"
                                                    class="dropdown-item cal-colorItem @(isSelected ? "active" : "")"
                                                    @onclick="() => SelectCalendar(cal.CalendarId)">
                                                <span class="cal-colorSwatch" style="background:@resHex"></span>
                                                <span class="cal-colorLabel">
                                                    @cal.Name@(cal.IsPrimary ? $" ({Loc.GetOr("Common_Calendars_Primary", "Primary")})" : "")
                                                </span>
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                </div>

                <div class="cal-formRow">
                    <div class="cal-timeRow">

                        @if (IsAllDay)
                        {
                            <div class="cal-field">
                                <label class="cal-label">@Loc.GetOr("Common_Date", "Datum")</label>
                                <input class="cal-input"
                                       type="date"
                                       value="@_startDateText"
                                       @oninput="OnStartDateChanged" />
                            </div>

                            <div class="cal-field">
                                <label class="cal-label">@Loc.GetOr("Common_Actions_To", "To")</label>
                                <input class="cal-input"
                                       type="date"
                                       value="@_endDateText"
                                       min="@_startDateText"
                                       @oninput="OnEndDateChanged" />
                            </div>
                        }
                        else
                        {
                            <div class="cal-field">
                                <label class="cal-label">@Loc.GetOr("Common_Actions_From", "From")</label>
                                <input class="cal-input"
                                       type="datetime-local"
                                       value="@_startText"
                                       @oninput="OnStartChanged"
                                       step="60" />
                            </div>

                            <div class="cal-field">
                                <label class="cal-label">@Loc.GetOr("Common_Actions_To", "To")</label>
                                <input class="cal-input"
                                       type="datetime-local"
                                       value="@_endText"
                                       min="@_startText"
                                       @oninput="OnEndChanged"
                                       step="60" />
                            </div>
                        }

                        <div class="cal-field cal-alldayField">
                            <button type="button"
                                    class="cal-alldayPill @(IsAllDay ? "is-on" : "")"
                                    @onclick="() => IsAllDay = !IsAllDay"
                                    aria-pressed="@IsAllDay">
                                @Loc.GetOr("Common_Actions_AllDay", "All day")
                            </button>
                        </div>
                    </div>
                </div>

                @* Description *@
                <div class="cal-formRow">
                    <label class="cal-label">@Loc.GetOr("Page_CalendarQuickAddModal_Description_Label", "Description")</label>
                    <textarea class="cal-input" rows="3" @bind="Model.Description"></textarea>
                </div>

                @* Location *@
                <div class="cal-formRow">
                    <label class="cal-label">@Loc.GetOr("Common_Location", "Location")</label>

                    <div class="cal-locationRow">
                        <input class="cal-input cal-locationInput"
                               @bind="Model.Location"
                               placeholder="@Loc.GetOr("Common_Location_Placeholder", "Address / place / link")" />

                        @if (CalendarLocationHelper.HasValue(Model.Location))
                        {
                            <a class="cal-locationIconLink"
                               target="_blank"
                               rel="noopener"
                               href="@CalendarLocationHelper.BuildOpenHref(Model.Location)"
                               aria-label="@CalendarLocationHelper.GetOpenLabel(Loc, Model.Location)"
                               title="@CalendarLocationHelper.GetOpenLabel(Loc, Model.Location)">
                                <a class="ui-iconBtn ui-iconBtn--sm ui-iconBtn--ghost cal-locationIconBtn"
                                   target="_blank"
                                   rel="noopener"
                                   href="@CalendarLocationHelper.BuildOpenHref(Model.Location)"
                                   aria-label="@CalendarLocationHelper.GetOpenLabel(Loc, Model.Location)"
                                   title="@CalendarLocationHelper.GetOpenLabel(Loc, Model.Location)">
                                    <i class="bi @(CalendarLocationHelper.IsLinkLike(Model.Location) ? "bi-box-arrow-up-right" : "bi-map")"
                                       aria-hidden="true"></i>
                                </a>
                            </a>
                        }
                    </div>

                    @if (CalendarLocationHelper.HasValue(Model.Location) && !CalendarLocationHelper.IsLinkLike(Model.Location))
                    {
                        <div class="cal-locationMapPreview">
                            <iframe title="@Loc.GetOr("Common_Action_OpenMap", "Open map")"
                                    loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade"
                                    src="@GetLocationMapEmbedUrl(Model.Location)">
                            </iframe>
                        </div>
                    }
                </div>

                @* Availability + Visibility *@
                <div class="cal-grid2 cal-grid2-collapse">

                    <div class="cal-field cal-select">
                        <label class="cal-label">@Loc.GetOr("Common_Availability", "Availability")</label>
                        <div class="dropdown">
                            <button type="button"
                                    class="cal-input cal-selectBtn dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                @GetAvailabilityLabel(Model.Availability)
                            </button>

                            <ul class="dropdown-menu cal-selectMenu">
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetAvailability(CalendarAvailability.Free)">
                                        @GetAvailabilityLabel(CalendarAvailability.Free)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetAvailability(CalendarAvailability.Busy)">
                                        @GetAvailabilityLabel(CalendarAvailability.Busy)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetAvailability(CalendarAvailability.OutOfOffice)">
                                        @GetAvailabilityLabel(CalendarAvailability.OutOfOffice)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetAvailability(CalendarAvailability.Tentative)">
                                        @GetAvailabilityLabel(CalendarAvailability.Tentative)
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="cal-field cal-select">
                        <label class="cal-label">@Loc.GetOr("Common_Visibility", "Visibility")</label>

                        <div class="dropdown">
                            <button type="button"
                                    class="cal-input cal-selectBtn dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                @GetVisibilityLabel(Model.Visibility)
                            </button>

                            <ul class="dropdown-menu cal-selectMenu">
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetVisibility(CalendarVisibility.Private)">
                                        @GetVisibilityLabel(CalendarVisibility.Private)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetVisibility(CalendarVisibility.BusyOnly)">
                                        @GetVisibilityLabel(CalendarVisibility.BusyOnly)
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item" @onclick="() => SetVisibility(CalendarVisibility.Details)">
                                        @GetVisibilityLabel(CalendarVisibility.Details)
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                @* Reminders *@
                <div class="cal-section">
                    <div class="cal-sectionHeader">
                        <div class="cal-sectionTitle">@Loc.GetOr("Common_Reminders", "Reminders")</div>
                        <span class="cal-sectionSwitch">
                            <input type="checkbox" class="cal-switch" @bind="RemindersEnabled" />
                        </span>
                    </div>

                    @if (RemindersEnabled)
                    {
                        <div class="cal-sectionBody">
                            @{
                                var r = Model.Reminders![0];
                                var presetLabel = GetPresetLabel(_reminderPreset);
                            }

                            <div class="cal-reminderRow">

                                <!-- Channel -->
                                <div class="cal-reminderCol">
                                    @if (CanSelectReminderChannel)
                                    {
                                        <div class="dropdown w-100">
                                            <button type="button"
                                                    class="cal-input cal-selectBtn dropdown-toggle w-100"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false">
                                                @GetReminderChannelLabel(r.Channel)
                                            </button>

                                            <ul class="dropdown-menu cal-selectMenu w-100">
                                                @foreach (var ch in ReminderChannels)
                                                {
                                                    var isSelected = r.Channel == ch;
                                                    <li>
                                                        <button type="button"
                                                                class="dropdown-item @(isSelected ? "active" : "")"
                                                                @onclick="() => SetReminderChannelSingle(ch)">
                                                            @GetReminderChannelLabel(ch)
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                    else
                                    {
                                        @* TODO: Kalenderpåminnelser – kanalval (Email/Push) för admins när backend + notifieringar är klara *@
                                        <div class="cal-input w-100">@GetReminderChannelLabel(ReminderChannel.InApp)</div>
                                    }
                                </div>

                                <!-- Preset -->
                                <div class="cal-reminderCol">
                                    <div class="dropdown w-100">
                                        <button type="button"
                                                class="cal-input cal-selectBtn dropdown-toggle w-100"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false">
                                            @presetLabel
                                        </button>

                                        <ul class="dropdown-menu cal-selectMenu w-100">
                                            @foreach (var p in ReminderPresets)
                                            {
                                                var isSelected = _reminderPreset == p.Value;
                                                <li>
                                                    <button type="button"
                                                            class="dropdown-item @(isSelected ? "active" : "")"
                                                            @onclick="() => SetReminderPreset(p.Value)">
                                                        @p.Label
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>

                                <!-- Custom minutes (only when Custom selected) -->
                                @if (_reminderPreset == "custom")
                                {
                                    <div class="cal-reminderCol cal-reminderCustom">
                                        <div class="cal-reminderCustomWrap">
                                            <input class="cal-input cal-reminderMinutes"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="r.MinutesBeforeStart" />

                                            <span class="cal-reminderUnit">
                                                @Loc.GetOr("Common_Minutes", "minutes")
                                            </span>
                                        </div>
                                    </div>
                                }

                            </div>
                        </div>
                    }
                </div>

                @* Recurrence *@
                <div class="cal-section">
                    <div class="cal-sectionHeader">
                        <div class="cal-sectionTitle">@Loc.GetOr("Common_Recurrence", "Recurrence")</div>

                        @if (IsOccurrenceEdit)
                        {
                            <span class="text-muted" style="font-size: var(--text-sm);">
                                @Loc.GetOr("Common_Recurrence_OccurrenceLocked", "This is a single occurrence. Edit the series from the original event.")
                            </span>

                            <button type="button"
                                    class="btn btn-ghost btn-sm"
                                    @onclick="() => OnEditSeries.InvokeAsync(ExistingEvent!)">
                                @Loc.GetOr("Common_Actions_EditSeries", "Edit series")
                            </button>
                        }
                        else
                        {
                            <span class="cal-sectionSwitch">
                                <input type="checkbox" class="cal-switch" checked="@HasRecurrence" @onchange="ToggleRecurrence" />
                            </span>
                        }
                    </div>

                    @if (!IsOccurrenceEdit && HasRecurrence)
                    {
                        <div class="cal-sectionBody">
                            @* (din befintliga recurrence-body exakt som idag) *@

                            <div class="cal-formRow cal-grid2" style="margin:0;">
                                <div class="cal-field cal-select">
                                    <label class="cal-label">@Loc.GetOr("Common_Frequency", "Frequency")</label>
                                    <div class="dropdown">
                                        <button type="button" class="cal-input cal-selectBtn dropdown-toggle" data-bs-toggle="dropdown">
                                            @GetRecurrenceFrequencyLabel(Model.Recurrence!.Frequency)
                                        </button>
                                        <ul class="dropdown-menu cal-selectMenu">
                                            @foreach (var f in Enum.GetValues<RecurrenceFrequency>())
                                            {
                                                var isSelected = Model.Recurrence!.Frequency == f;
                                                <li>
                                                    <button type="button"
                                                            class="dropdown-item @(isSelected ? "active" : "")"
                                                            @onclick="() => SetRecurrenceFrequency(f)">
                                                        @GetRecurrenceFrequencyLabel(f)
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>

                                <div class="cal-field">
                                    <label class="cal-label">@Loc.GetOr("Common_Interval", "Interval")</label>
                                    <input class="cal-input" type="number" min="1" step="1" @bind="Model.Recurrence!.Interval" />
                                </div>
                            </div>

                            @if (Model.Recurrence?.Frequency == RecurrenceFrequency.Weekly)
                            {
                                <div class="cal-formRow" style="margin-top:10px;">
                                    <label class="cal-label">@Loc.GetOr("Common_Days", "Days")</label>
                                    <div class="cal-chipRow">
                                        @foreach (var d in WeekdayOptions)
                                        {
                                            var selected = Model.Recurrence!.ByWeekDays.Contains(d);
                                            <button type="button"
                                                    class="cal-chip @(selected ? "is-on" : "")"
                                                    @onclick="() => ToggleWeekday(d)">
                                                @GetWeekdayShortLabel(d)
                                            </button>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="cal-formRow cal-grid2" style="margin-top:10px;">
                                <div class="cal-field cal-select">
                                    <label class="cal-label">@Loc.GetOr("Common_EndMode", "Ends")</label>

                                    <div class="dropdown">
                                        <button type="button" class="cal-input cal-selectBtn dropdown-toggle" data-bs-toggle="dropdown">
                                            @GetRecurrenceEndModeLabel(_recurrenceEndMode)
                                        </button>

                                        <ul class="dropdown-menu cal-selectMenu">
                                            @foreach (var m in RecurrenceEndModes)
                                            {
                                                var isSelected = string.Equals(_recurrenceEndMode, m.Value, StringComparison.Ordinal);
                                                <li>
                                                    <button type="button"
                                                            class="dropdown-item @(isSelected ? "active" : "")"
                                                            @onclick="() => SetRecurrenceEndMode(m.Value)">
                                                        @m.Label
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>

                                <div class="cal-field">
                                    @if (_recurrenceEndMode == "until")
                                    {
                                        <label class="cal-label">@Loc.GetOr("Common_Until", "Until")</label>
                                        <input class="cal-input" type="date" value="@_recurrenceUntilLocalText" @oninput="OnRecurrenceUntilChanged" />
                                    }
                                    else if (_recurrenceEndMode == "count")
                                    {
                                        <label class="cal-label">@Loc.GetOr("Common_Count", "Count")</label>
                                        <input class="cal-input" type="number" min="1" step="1" @bind="Model.Recurrence!.Count" />
                                    }
                                    else
                                    {
                                        <label class="cal-label">&nbsp;</label>
                                        <div class="cal-input" style="opacity:0; pointer-events:none;">.</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Checklist *@
                <div class="cal-section">
                    <div class="cal-sectionHeader">
                        <div class="cal-sectionTitle">@Loc.GetOr("Common_Checklist", "Checklist")</div>

                        <span class="cal-sectionSwitch">
                            <input type="checkbox" class="cal-switch" @bind="ChecklistEnabled" />
                        </span>
                    </div>

                    @if (ChecklistEnabled)
                    {
                        <div class="cal-sectionBody">
                            <div class="cal-miniList">
                                @for (var i = 0; i < (Model.Checklist?.Count ?? 0); i++)
                                {
                                    var item = Model.Checklist![i];

                                    <div class="cal-miniRow cal-miniRowChecklist" @key="item">
                                        <input type="checkbox"
                                               class="form-check-input cal-checklistBox"
                                               @bind="item.Done" />

                                        <input class="cal-input cal-miniInput cal-checklistInput"
                                               @bind="item.Text"
                                               placeholder="@Loc.GetOr("Common_ChecklistItem_Placeholder", "Checklist item")" />

                                        <IconButton IconClass="bi bi-trash"
                                                    Title="@Loc.GetOr("Common_Actions_Delete", "Delete")"
                                                    AriaLabel="@Loc.GetOr("Common_Actions_Delete", "Delete")"
                                                    Size="sm"
                                                    Tone="ghost"
                                                    Class="cal-dayRowIconBtn cal-checklistTrash"
                                                    OnClick="@(e => { RemoveChecklistItem(item); return Task.CompletedTask; })" />
                                    </div>
                                }

                                <IconButton IconClass="bi bi-plus-lg"
                                            Title="@Loc.GetOr("Common_Actions_Add", "Add")"
                                            AriaLabel="@Loc.GetOr("Common_Actions_Add", "Add")"
                                            Size="sm"
                                            Tone="ghost"
                                            Class="cal-dayRowIconBtn cal-checklistAddBtn"
                                            OnClick="@(e => { AddChecklistItem(); return Task.CompletedTask; })" />
                            </div>
                        </div>
                    }
                </div>

            </div>

            <div class="cal-modalFooter">
                @if (IsEdit)
                {
                    <button type="button"
                            class="btn btn-ghost"
                            @onclick="DeleteAsync">
                        @Loc.GetOr("Common_Actions_Delete", "Delete")
                    </button>
                }

                <div style="flex:1"></div>

                <button type="button" class="btn btn-ghost" @onclick="RequestCloseAsync">
                    @Loc.GetOr("Common_Actions_Cancel", "Cancel")
                </button>
                <button type="button"
                        class="btn btn-primary"
                        disabled="@(!HasEditableCalendar)"
                        @onclick="SaveAsync">
                    @Loc.GetOr("Common_Actions_Save", "Save")
                </button>

                @if (!HasEditableCalendar)
                {
                    <div class="alert alert-warning mt-2">
                        @Loc.GetOr("Page_CalendarQuickAddModal_NoEditableCalendars", "You don't have permission to create events in any calendar.")
                    </div>
                }
            </div>
        </div>
    </div>
}

<ConfirmModal @ref="_confirmClose"
              ModalOptions="@(new { backdrop = false, keyboard = false })"
              Title="@Loc.GetOr("ConfirmModal_Title_UnsavedChanges", "Unsaved changes")"
              Message="@Loc.GetOr("ConfirmModal_Message_UnsavedChanges", "Du har osparade ändringar. Vill du kasta dem?")"
              Variant="warning"
              CancelText="@Loc.GetOr("Common_Actions_Cancel", "Cancel")"
              ConfirmText="@Loc.GetOr("Common_Actions_Discard", "Discard")"
              OnClosed="OnConfirmCloseClosed" />

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter] public List<CalendarDto> Calendars { get; set; } = new();
    [Parameter] public string? DefaultCalendarId { get; set; }
    [Parameter] public Func<string?, string>? CalendarIdToHex { get; set; }

    [Parameter] public DateTime DefaultStartLocal { get; set; }
    [Parameter] public DateTime DefaultEndLocal { get; set; }

    [Parameter] public CalendarEventDto? ExistingEvent { get; set; }

    [Parameter] public EventCallback<CalendarEventDto> OnSave { get; set; }
    [Parameter] public EventCallback<CalendarEventDto> OnDelete { get; set; }
    [Parameter] public EventCallback<CalendarEventDto> OnEditSeries { get; set; }

    private CalendarEventDto Model = new();

    private ConfirmModal? _confirmClose;
    private TaskCompletionSource<bool>? _confirmTcs;

    private string _initialSnapshot = "";
    private bool _scrollLocked;
    private ElementReference _modalRef;

    private DateTime _startLocal;
    private DateTime _endLocal;

    private bool _endTouched;
    private TimeSpan _duration = TimeSpan.FromMinutes(30);

    // All-day UI (date only)
    private string _startDateText = ""; // yyyy-MM-dd
    private string _endDateText = "";   // yyyy-MM-dd (inclusive display)
    private int _allDayDays = 1;        // number of days, end is exclusive in model

    // Date-time UI
    private string _startText = "";
    private string _endText = "";

    private string? SelectedCalendarId;

    private bool HasManyCalendars => (Calendars?.Count ?? 0) > 1;
    private bool IsEdit => ExistingEvent is not null && !string.IsNullOrWhiteSpace(ExistingEvent.EventId);

    private static readonly CultureInfo Invariant = CultureInfo.InvariantCulture;
    private static readonly string[] DtFormats =
    [
        "yyyy-MM-ddTHH:mm",
        "yyyy-MM-ddTHH:mm:ss"
    ];

    private bool _wasOpen;
    private string? _lastEventId;

    private bool HasEditableCalendar => Calendars?.Count > 0;

    // Recurrence UI state
    private string _recurrenceEndMode = "none"; // none | until | count
    private string _recurrenceUntilLocalText = "";

    private static readonly DayOfWeek[] WeekdayOptions =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    ];

    private static readonly ReminderChannel[] ReminderChannels = Enum.GetValues<ReminderChannel>();
    private bool _reminderChannelsFeatureEnabled;
    private bool _reminderChannelsSelectionEnabled;
    private string _reminderPreset = "30";

    private bool CanUserChooseReminderChannel => _reminderChannelsFeatureEnabled;
    private bool CanEnableReminderChannelSelection => CanUserChooseReminderChannel && _reminderChannelsSelectionEnabled;
    private bool CanSelectReminderChannel => CanUserChooseReminderChannel && CanEnableReminderChannelSelection;

    private bool HasRecurrence => Model.Recurrence is not null;

    private bool RemindersEnabled
    {
        get => Model.Reminders is not null && Model.Reminders.Count > 0;
        set
        {
            if (value)
            {
                Model.Reminders ??= new();
                if (Model.Reminders.Count == 0)
                {
                    Model.Reminders.Add(new ReminderDto
                    {
                        Channel = ReminderChannel.InApp,
                        MinutesBeforeStart = 30
                    });
                }
                else if (Model.Reminders.Count > 1)
                {
                    // vi vill bara ha en
                    Model.Reminders = new List<ReminderDto> { Model.Reminders[0] };
                }
            }
            else
            {
                Model.Reminders = new();
            }
        }
    }

