@* ContentLibrarySection.razor component *@
<div class="card mb-4 content-library">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start align-items-md-center gap-3 mb-3">
            <div class="flex-grow-1">
                <h2 class="section-title mb-1">
                    <i class="bi bi-journals me-2" aria-hidden="true"></i>
                    @L("Page_Home_ContentLibrary_Text", "Content Library")
                </h2>

                <p class="text-muted mb-0">
                    @LibraryCount @L("Page_Home_ReadyMadeTextsToUse_Text", "ready-made texts and ideas to use")
                </p>
            </div>

            <button type="button"
                    class="btn btn-outline-secondary flex-shrink-0"
                    @onclick="OnExport">
                <i class="bi bi-floppy me-2" aria-hidden="true"></i>
                @L("Page_Home_ExportData_Button", "Export data")
            </button>
        </div>

        <button type="button"
                class="btn btn-primary content-library__cta"
                @onclick="@(() => OnNavigate.InvokeAsync("library"))">
            @L("Page_Home_ExploreContentLibrary_Button", "Explore the Content Library")
            <span aria-hidden="true"> →</span>
        </button>
    </div>
</div>

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;
    [Parameter, EditorRequired] public int LibraryCount { get; set; }
    [Parameter, EditorRequired] public EventCallback<string> OnNavigate { get; set; }
    [Parameter, EditorRequired] public EventCallback OnExport { get; set; }

    private string L(string key, string fallback)
    {
        try
        {
            var value = (string?)Loc?[key];

            // Om Loc saknas eller returnerar nyckeln själv → fallback
            if (string.IsNullOrWhiteSpace(value) || string.Equals(value, key, StringComparison.Ordinal))
                return fallback;

            return value;
        }
        catch
        {
            return fallback;
        }
    }
}
