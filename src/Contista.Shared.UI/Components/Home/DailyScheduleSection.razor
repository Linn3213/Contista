@* DailySchedukeSection.razor component *@
<div class="card mb-4 daily-schedule">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start align-items-md-center gap-3 mb-4">
            <div class="flex-grow-1">
                <h2 class="section-title mb-1">
                    <i class="bi bi-calendar3 me-2" aria-hidden="true"></i>
                    @L("Page_Home_DailySchedule_Title", "Today's schedule")
                </h2>
                <p class="text-muted mb-0">
                    @L("Page_Home_DailySchedule_Subtitle", "Your daily routine & activities")
                </p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="button"
                        class="btn btn-primary"
                        @onclick="OnAddActivity">
                    <i class="bi bi-plus-lg me-2" aria-hidden="true"></i>
                    @L("Page_Home_DailySchedule_Add_Button", "Add activity")
                </button>

                <button type="button"
                        class="btn btn-outline-secondary"
                        @onclick="OnReset">
                    <i class="bi bi-arrow-clockwise me-2" aria-hidden="true"></i>
                    @L("Page_Home_DailySchedule_Reset_Button", "Restore")
                </button>
            </div>
        </div>

        @if (HasItems)
        {
            @ChildContent
        }
        else
        {
            <div class="daily-schedule__empty text-center p-4 p-md-5">
                <div class="daily-schedule__empty-icon mb-3" aria-hidden="true">
                    <i class="bi bi-calendar3"></i>
                </div>

                <h3 class="daily-schedule__empty-title mb-2">
                    @L("Page_Home_DailySchedule_Empty_Title", "Your schedule is empty")
                </h3>

                <p class="text-muted mb-0">
                    @L("Page_Home_DailySchedule_Empty_Text", "Click \"Add Activity\" to start planning your day")
                </p>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;
    [Parameter] public bool HasItems { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter, EditorRequired] public EventCallback OnAddActivity { get; set; }
    [Parameter, EditorRequired] public EventCallback OnReset { get; set; }

    private string L(string key, string fallback)
    {
        try
        {
            var value = (string?)Loc?[key];
            if (string.IsNullOrWhiteSpace(value) || string.Equals(value, key, StringComparison.Ordinal))
                return fallback;
            return value;
        }
        catch
        {
            return fallback;
        }
    }
}
