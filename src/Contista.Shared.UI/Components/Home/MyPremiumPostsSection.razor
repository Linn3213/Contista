@* MyPremiumPostsSection.razor component *@
<div class="my-posts card mb-4 p-4 p-md-4">
    <div class="d-flex justify-content-between align-items-start align-items-md-center gap-3 mb-3">
        <div class="flex-grow-1">
            <h2 class="section-title mb-1">
                <i class="bi bi-pencil-square me-2" aria-hidden="true"></i>
                @DisplayTitle
            </h2>
            <p class="text-muted mb-0">
                @SavedCount @Loc["Page_Home_MyPremiumPostsSection_SavedCount_Text"]
            </p>
        </div>

        <button type="button"
                class="btn btn-outline-secondary flex-shrink-0"
                @onclick="OnSeeAll">
            @Loc["Page_Home_MyPremiumPostsSection_SeeAll_Button"] <span aria-hidden="true">→</span>
        </button>
    </div>

    @if (SavedCount <= 0)
    {
        <div class="my-posts__empty text-center p-4 p-md-5">
            <p class="text-muted m-0">
                @Loc["Page_Home_MyPremiumPostsSection_NoPostsExists_Text"]
            </p>

            <button type="button"
                    class="btn btn-primary mt-3"
                    @onclick="OnCreatePost">
                <i class="bi bi-stars me-2" aria-hidden="true"></i>
                @Loc["Page_Home_MyPremiumPostsSection_CreatePost_Button"]
            </button>
        </div>
    }
    else
    {
        <div class="my-posts__empty text-center p-4 p-md-5">
            <p class="text-muted m-0">
                @Loc["Page_Home_MyPremiumPostsSection_YouHave_Text"]
                @SavedCount
                @Loc["Page_Home_MyPremiumPostsSection_SavedCount_Text"]
            </p>

            <button type="button"
                    class="btn btn-outline-secondary mt-3"
                    @onclick="OnSeeAll">
                @Loc["Page_Home_MyPremiumPostsSection_ShowPost_Button"] <span aria-hidden="true">→</span>
            </button>
        </div>
    }
</div>

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;
    [Parameter] public string? Title { get; set; }
    [Parameter] public int SavedCount { get; set; } = 0;

    [Parameter] public EventCallback OnSeeAll { get; set; }
    [Parameter] public EventCallback OnCreatePost { get; set; }

    private string DisplayTitle =>
    Title ?? (Loc?["Page_Home_MyPremiumPostsSection_Title"] ?? "My Premium Posts");
}
