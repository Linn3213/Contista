@* MiniLoader.razor component *@
@if (Visible)
{
    <div class="app-mini-loader-overlay fade-in">
        <div class="app-mini-loader-box">
            <div class="spinner-border app-mini-loader-spinner" role="status" aria-label="@DisplayMessage"></div>
            <span>@DisplayMessage</span>
        </div>
    </div>
}

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string? Message { get; set; }

    private string DisplayMessage => string.IsNullOrWhiteSpace(Message)
        ? Loc["Common_Messages_Loading"]
        : Message!;
}
