@* IconButton.razor *@

<button type="button"
        class="@ComputedClass"
        title="@Title"
        aria-label="@ComputedAriaLabel"
        disabled="@Disabled"
        @onclick="HandleClick">
    <i class="@IconClass" aria-hidden="true"></i>
</button>

@code {
    [Parameter, EditorRequired] public string IconClass { get; set; } = "bi bi-plus-lg";

    [Parameter] public string? Title { get; set; }
    [Parameter] public string? AriaLabel { get; set; }

    [Parameter] public string Size { get; set; } = "md";      // xs | sm | md
    [Parameter] public string Tone { get; set; } = "ghost";   // ghost | subtle | solid
    [Parameter] public bool Round { get; set; } = false;
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool StopPropagation { get; set; } = false;

    [Parameter] public string? Class { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    private string ComputedAriaLabel
        => !string.IsNullOrWhiteSpace(AriaLabel)
            ? AriaLabel!
            : (!string.IsNullOrWhiteSpace(Title) ? Title! : "Action");

    private string ComputedClass
    {
        get
        {
            var classes = new List<string>
            {
                "ui-iconBtn",
                $"ui-iconBtn--{NormalizeSize(Size)}",
                $"ui-iconBtn--{NormalizeTone(Tone)}"
            };

            if (Round)
                classes.Add("ui-iconBtn--round");

            if (Disabled)
                classes.Add("is-disabled");

            if (!string.IsNullOrWhiteSpace(Class))
                classes.Add(Class!);

            return string.Join(" ", classes);
        }
    }

    private static string NormalizeSize(string? size)
    => size?.Trim().ToLowerInvariant() switch
    {
        "xs" => "xs",
        "sm" => "sm",
        "lg" => "lg",
        _ => "md"
    };

    private static string NormalizeTone(string? tone)
        => tone?.Trim().ToLowerInvariant() switch
        {
            "subtle" => "subtle",
            "solid" => "solid",
            _ => "ghost"
        };

    private Task HandleClick(MouseEventArgs e)
        => Disabled ? Task.CompletedTask : OnClick.InvokeAsync(e);
}