@* SyncDebug_NetworkPanel.razor *@
@using Contista.Shared.Core.Offline.Interfaces
@inject INetworkStatus Network
@inject INetworkDebugControl NetDebug

@implements IDisposable

<hr />
<h3 class="page-subtitle">Network (DEBUG)</h3>

<p class="small la-muted">
    @Loc["Page_SyncDebug_NetworkPanel_NetworkType_Text"]: <b>@Network.GetType().Name</b><br />
    @Loc["Page_SyncDebug_NetworkPanel_DebugPanel_Text"]: <b>@NetDebug.GetType().Name</b><br />
    @Loc["Page_SyncDebug_NetworkPanel_EffectiveOnline_Text"]: <b>@(Network.IsOnline ? "true" : "false")</b>
</p>

@if (!NetDebug.IsSupported)
{
    <p class="small la-muted">
        @Loc["Page_SyncDebug_NetworkPanel_DebugOverrideIsNotSupported_Text"]
    </p>
}
else
{
    <p class="small la-muted">
        Override:
        <b>
            @(NetDebug.ForcedOnline is null
                    ? Loc["Page_SyncDebug_NetworkPanel_NORMAL_Text"]
                    : (NetDebug.ForcedOnline.Value ? Loc["Page_SyncDebug_NetworkPanel_ForcedOnline_Text"] : Loc["Page_SyncDebug_NetworkPanel_ForcedOffline_Text"]))
        </b>
    </p>

    <div class="form-actions" style="display:flex; gap:.5rem; flex-wrap:wrap;">
        <button class="btn" @onclick="() => SetForce(false)">@Loc["Page_SyncDebug_NetworkPanel_ForcedOffline_Button"]</button>
        <button class="btn" @onclick="() => SetForce(true)">@Loc["Page_SyncDebug_NetworkPanel_ForcedOnline_Button"]</button>
        <button class="btn" @onclick="() => SetForce(null)">@Loc["Page_SyncDebug_NetworkPanel_Normal_Button"]</button>
    </div>
}

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;
    protected override void OnInitialized()
    {
        Network.OnlineChanged += OnOnlineChanged;
    }

    private void SetForce(bool? forced)
    {
        NetDebug.Force(forced);
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnOnlineChanged(bool online)
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Network.OnlineChanged -= OnOnlineChanged;
    }
}
