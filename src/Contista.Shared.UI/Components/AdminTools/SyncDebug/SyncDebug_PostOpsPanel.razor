@* SyncDebug_PostOpsPanel.razor component *@
@using Contista.Shared.Core.Models
@using Contista.Shared.Core.Interfaces.SyncDebug

<div>
    <h3 class="page-subtitle">@Loc["Page_SyncDebug_PostOpsPanel_SubTitle1"]</h3>

    <div class="form-actions" style="display:flex; gap:.5rem; flex-wrap:wrap;">
        <button class="btn" @onclick="Vm.QueueCreatePostOnlyAsync">@Loc["Page_SyncDebug_PostOpsPanel_QueueCreatePost_Button"]</button>
        <button class="btn" @onclick="Vm.QueueCreateRoleOnlyAsync">@Loc["Page_SyncDebug_PostOpsPanel_QueueCreateRole_Button"]</button>
        <button class="btn" @onclick="Vm.QueueCreateMembershipOnlyAsync">@Loc["Page_SyncDebug_PostOpsPanel_QueueCreateMembership_Button"]</button>
    </div>

    <hr />

    <h3 class="page-subtitle">@Loc["Page_SyncDebug_PostOpsPanel_SubTitle2"]</h3>

    @if (Vm.PostsUi.Count == 0)
    {
        <p class="small la-muted">@Loc["Page_SyncDebug_PostOpsPanel_NoPostInState_Text"]</p>
    }
    else
    {
        <div class="form-actions" style="display:flex; gap:.5rem; flex-wrap:wrap; align-items:center;">
            <label class="small la-muted" style="margin:0;">@Loc["Page_SyncDebug_PostOpsPanel_SelectPost_Text"]:</label>

            <select class="form-select" style="max-width:420px;" @bind="Vm.SelectedPostId">
                @foreach (var p in Vm.PostsUi.OrderByDescending(x => x.UpdatedDate))
                {
                    <option value="@p.PostId">@($"{p.Title} ({p.PostId})")</option>
                }
            </select>

            <button class="btn"
                    @onclick="Vm.QueueUpdateSelectedPostOnlyAsync"
                    disabled="@(!Vm.CanUpdateOrDeleteSelectedPost)">
                Queue UpdatePost (only)
            </button>

            <button class="btn"
                    @onclick="Vm.QueueDeleteSelectedPostOnlyAsync"
                    disabled="@(!Vm.CanUpdateOrDeleteSelectedPost)">
                Queue DeletePost (only)
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Vm.PostOpsMessage))
        {
            <p class="form-message">@Vm.PostOpsMessage</p>
        }
    }
</div>

@code {
    [CascadingParameter] public ILocalizationService Loc { get; set; } = default!;
    [Parameter] public ISyncDebugController Vm { get; set; } = default!;
}
