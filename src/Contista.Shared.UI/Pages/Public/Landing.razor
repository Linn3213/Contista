@code {
    // läses från query: /?returnUrl=%2Fapp%2Fhome
    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private bool _loginBusy;
    private bool _checkingOrRedirecting = true;

    private Task OnLoginBusyChanged(bool busy)
    {
        _loginBusy = busy;
        return InvokeAsync(StateHasChanged);
    }

    protected override void OnInitialized()
    {
        CommonState.Changed += OnCommonChanged;
        Network.OnlineChanged += OnOnlineChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Håll kvar loader tills vi vet säkert
        _checkingOrRedirecting = true;

        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            // Viktigt: håll kvar loader, rendera inte Landing
            Nav.NavigateTo(ResolvePostLoginTarget(ReturnUrl), replace: true);
            return;
        }

        // Bara här släpper vi fram Landing
        _checkingOrRedirecting = false;
    }

    private void OnOnlineChanged(bool online)
     => _ = InvokeAsync(StateHasChanged);

    private void GoRegister()
    {
        // valfritt: behåll returnUrl även vid register så du kan hoppa tillbaka sen
        var target = "/register";
        var ru = NormalizeReturnUrl(ReturnUrl);
        if (!string.IsNullOrWhiteSpace(ru) && ru != "/")
            target += "?returnUrl=" + Uri.EscapeDataString(ru);

        Nav.NavigateTo(target);
    }

    private void GoExplore() => Nav.NavigateTo("/about");

    private void OnCommonChanged() => _ = InvokeAsync(StateHasChanged);

    private Task OnLoggedInAsync(string? returnUrlFromLoginCard)
    {
        // LoginCard skickar tillbaka (oftast samma som ReturnUrl)
        Nav.NavigateTo(ResolvePostLoginTarget(returnUrlFromLoginCard), replace: true);
        return Task.CompletedTask;
    }

    private static string ResolvePostLoginTarget(string? returnUrl)
    {
        var ru = NormalizeReturnUrl(returnUrl);
        return IsSafeReturnUrl(ru) ? ru! : "/app/home";
    }

    private static string? NormalizeReturnUrl(string? returnUrl)
    {
        var ru = (returnUrl ?? "").Trim();
        if (string.IsNullOrWhiteSpace(ru))
            return null;

        if (!ru.StartsWith("/"))
            ru = "/" + ru;

        return ru;
    }

    private static bool IsSafeReturnUrl(string? ru)
    {
        if (string.IsNullOrWhiteSpace(ru))
            return false;

        // måste vara local path
        if (!ru.StartsWith("/"))
            return false;

        // blockera protocol-relative och backslash-varianter
        if (ru.StartsWith("//") || ru.StartsWith("/\\"))
            return false;

        // blockera absolut-url i smyg
        if (ru.Contains("://", StringComparison.OrdinalIgnoreCase))
            return false;

        return true;
    }

    public void Dispose()
    {
        CommonState.Changed -= OnCommonChanged;
        Network.OnlineChanged -= OnOnlineChanged;
    }
}
