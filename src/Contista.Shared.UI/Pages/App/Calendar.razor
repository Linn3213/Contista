    private async Task SaveEditAsync(CalendarEventDto updated)
    {
        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        if (string.IsNullOrWhiteSpace(updated.CalendarId))
            return;

        var all = CalendarState.Current?.Events ?? new List<CalendarEventDto>();
        var conflicts = FindBlockingConflicts(updated, CurrentUserId, all);

        InlineInfo = conflicts.Count > 0
            ? ConflictSummaryText(updated, conflicts, CurrentUserId)
            : null;

        if (IsSyntheticOccurrence(updated))
        {
            var opId = Guid.NewGuid().ToString("N");

            var ex = BuildOverrideException(updated, Auth.Uid!);

            ex.EventId = "temp_" + opId;
            ex.LastMutationId = opId;
            ex.StartUtc = DateTimes.AsUtc(ex.StartUtc);
            ex.EndUtc = DateTimes.AsUtc(ex.EndUtc);

            await CalendarState.OptimisticAddEventAsync(ex, CancellationToken.None);

            var dto = new CreateCalendarEventOperationDto { Event = ex };

            var env = new SyncOperationEnvelope
            {
                ClientOperationId = opId,
                UserId = Auth.Uid!,
                OperationType = SyncOperationType.CreateCalendarEvent,
                ClientTimestampUtc = DateTime.UtcNow,
                Payload = JsonSerializer.SerializeToElement(dto, JsonOpts)
            };

            await OfflineWrite.EnqueueAsync(env);

            if (Network.IsOnline)
            {
                await AutoSync.TrySyncSoonAsync(async () =>
                {
                    await SyncRunner.RunOnceAsync();
                    await RefreshNowAsync(force: true);
                    RefreshDayModalStateFromCurrentData();
                });
            }
            else
            {
                InlineInfo = Loc.GetOr("Page_Calendar_QueuedOffline_Info", "Saved offline. It will sync when you are back online.");
                RefreshDayModalStateFromCurrentData();
            }

            return;
        }

        if (string.IsNullOrWhiteSpace(updated.EventId))
            return;

        var opId2 = Guid.NewGuid().ToString("N");
        updated.LastMutationId = opId2;
        updated.StartUtc = DateTimes.AsUtc(updated.StartUtc);
        updated.EndUtc = DateTimes.AsUtc(updated.EndUtc);

        await CalendarState.OptimisticUpdateEventAsync(updated, CancellationToken.None);

        var dto2 = new UpdateCalendarEventOperationDto
        {
            Event = updated,
            LastKnownUpdatedAtUtc = updated.UpdatedAtUtc
        };

        var env2 = new SyncOperationEnvelope
        {
            ClientOperationId = opId2,
            UserId = Auth.Uid!,
            OperationType = SyncOperationType.UpdateCalendarEvent,
            ClientTimestampUtc = DateTime.UtcNow,
            Payload = JsonSerializer.SerializeToElement(dto2, JsonOpts)
        };

        await OfflineWrite.EnqueueAsync(env2);

        if (_isDayModalOpen && !string.IsNullOrWhiteSpace(updated.EventId))
        {
            _dayModalEventId = updated.EventId;
            _dayModalFocusEventId = updated.EventId;
            _dayModalDateLocal = DateTimes.ToLocalFromUtc(updated.StartUtc).Date;
            TouchDayModal();
        }

        if (Network.IsOnline)
        {
            await AutoSync.TrySyncSoonAsync(async () =>
            {
                await SyncRunner.RunOnceAsync();
                await RefreshNowAsync(force: true);
                RefreshDayModalStateFromCurrentData();
            });
        }
        else
        {
            InlineInfo = Loc.GetOr("Page_Calendar_QueuedOffline_Info", "Saved offline. It will sync when you are back online.");
            RefreshDayModalStateFromCurrentData();
        }
    }

    private async Task DeleteEventAsync(CalendarEventDto ev)
    {
        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        if (string.IsNullOrWhiteSpace(ev.CalendarId))
            return;

        var deletedEventId = ev.EventId;
        var deletedDay = DateTimes.ToLocalFromUtc(ev.StartUtc).Date;

        if (IsSyntheticOccurrence(ev))
        {
            var opId = Guid.NewGuid().ToString("N");

            var cancel = BuildCancelException(ev, Auth.Uid!);
            cancel.EventId = "temp_" + opId;
            cancel.LastMutationId = opId;

            cancel.StartUtc = DateTimes.AsUtc(cancel.StartUtc);
            cancel.EndUtc = DateTimes.AsUtc(cancel.EndUtc);

            await CalendarState.OptimisticAddEventAsync(cancel, CancellationToken.None);

            var dto = new CreateCalendarEventOperationDto { Event = cancel };

            var env = new SyncOperationEnvelope
            {
                ClientOperationId = opId,
                UserId = Auth.Uid!,
                OperationType = SyncOperationType.CreateCalendarEvent,
                ClientTimestampUtc = DateTime.UtcNow,
                Payload = JsonSerializer.SerializeToElement(dto, JsonOpts)
            };

            await OfflineWrite.EnqueueAsync(env);

            if (_isDayModalOpen && !string.IsNullOrWhiteSpace(deletedEventId) &&
                string.Equals(_dayModalEventId, deletedEventId, StringComparison.Ordinal))
            {
                _dayModalEventId = null;
                _dayModalFocusEventId = null;
                _dayModalDateLocal = deletedDay;
                TouchDayModal();
            }

            if (Network.IsOnline)
            {
                await AutoSync.TrySyncSoonAsync(async () =>
                {
                    await SyncRunner.RunOnceAsync();
                    await RefreshNowAsync(force: true);
                    RefreshDayModalStateFromCurrentData();
                });
            }
            else
            {
                InlineInfo = Loc.GetOr("Page_Calendar_QueuedOffline_Info", "Saved offline. It will sync when you are back online.");
                RefreshDayModalStateFromCurrentData();
            }

            return;
        }

        if (string.IsNullOrWhiteSpace(ev.EventId))
            return;

        var opId2 = Guid.NewGuid().ToString("N");

        await CalendarState.OptimisticDeleteEventAsync(ev.EventId!, CancellationToken.None);

        var dto2 = new DeleteCalendarEventOperationDto
        {
            CalendarId = ev.CalendarId,
            EventId = ev.EventId!
        };

        var env2 = new SyncOperationEnvelope
        {
            ClientOperationId = opId2,
            UserId = Auth.Uid!,
            OperationType = SyncOperationType.DeleteCalendarEvent,
            ClientTimestampUtc = DateTime.UtcNow,
            Payload = JsonSerializer.SerializeToElement(dto2, JsonOpts)
        };

        await OfflineWrite.EnqueueAsync(env2);

        if (_isDayModalOpen && !string.IsNullOrWhiteSpace(deletedEventId) &&
            string.Equals(_dayModalEventId, deletedEventId, StringComparison.Ordinal))
        {
            _dayModalEventId = null;
            _dayModalFocusEventId = null;
            _dayModalDateLocal = deletedDay;
            TouchDayModal();
        }

        if (Network.IsOnline)
        {
            await AutoSync.TrySyncSoonAsync(async () =>
            {
                await SyncRunner.RunOnceAsync();
                await RefreshNowAsync(force: true);
                RefreshDayModalStateFromCurrentData();
            });
        }
        else
        {
            InlineInfo = Loc.GetOr("Page_Calendar_QueuedOffline_Info", "Saved offline. It will sync when you are back online.");
            RefreshDayModalStateFromCurrentData();
        }
    }

