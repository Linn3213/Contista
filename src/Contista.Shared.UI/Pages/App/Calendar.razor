    private async Task OnQuickAddSaveAsync(CalendarEventDto created)
    {
        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        if (string.IsNullOrWhiteSpace(created.CalendarId))
            created.CalendarId = GetDefaultCreateCalendarIdForModal();

        if (string.IsNullOrWhiteSpace(created.CalendarId))
            return;

        var editable = GetEditableCalendars(CalendarState.Current?.My?.Calendars?.ToList() ?? new());
        if (!editable.Any(c => c.CalendarId == created.CalendarId))
            return;

        var all = CalendarState.Current?.Events ?? new List<CalendarEventDto>();
        var conflicts = CalendarConflictDetector.FindBlockingConflicts(
            created,
            all,
            ev => EffectiveVisibilityForViewer(ev, CurrentUserId)
        );

        InlineInfo = conflicts.Count > 0
            ? ConflictSummaryText(created, conflicts, CurrentUserId)
            : null;

        var opId = Guid.NewGuid().ToString("N");

        created.EventId ??= "temp_" + opId;
        created.LastMutationId = opId;
        created.StartUtc = DateTimes.AsUtc(created.StartUtc);
        created.EndUtc = DateTimes.AsUtc(created.EndUtc);
        created.CreatedById = Auth.Uid;

        await CalendarState.OptimisticAddEventAsync(created, CancellationToken.None);

        if (created.Recurrence is not null && string.IsNullOrWhiteSpace(created.Recurrence.SeriesId))
            created.Recurrence.SeriesId = Guid.NewGuid().ToString("N");

        var dto = new CreateCalendarEventOperationDto { Event = created };

        var env = new SyncOperationEnvelope
        {
            ClientOperationId = opId,
            UserId = Auth.Uid!,
            OperationType = SyncOperationType.CreateCalendarEvent,
            ClientTimestampUtc = DateTime.UtcNow,
            Payload = JsonSerializer.SerializeToElement(dto, JsonOpts)
        };

        await OfflineWrite.EnqueueAsync(env);

        IsQuickAddOpen = false;

        if (Network.IsOnline)
        {
            await AutoSync.TrySyncSoonAsync(async () =>
            {
                await SyncRunner.RunOnceAsync();
                await RefreshNowAsync(force: true);
                RefreshDayModalStateFromCurrentData();
            });
        }
        else
        {
            InlineInfo = Loc.GetOr("Page_Calendar_QueuedOffline_Info", "Saved offline. It will sync when you are back online.");
            RefreshDayModalStateFromCurrentData();
        }
    }

