        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        if (cal is null || string.IsNullOrWhiteSpace(cal.CalendarId))
            return;

        if (cal.IsPrimary)
        {
            InlineInfo = Loc.GetOr("Page_Calendar_PrimaryCannotEdit", "The primary (Contista) calendar cannot be edited.");
            return;
        }

        cal.Color = CalendarColors.Normalize(cal.Color);

        var opId = Guid.NewGuid().ToString("N");
        cal.LastMutationId = opId;

        var dto = new UpdateCalendarOperationDto { Calendar = cal };

        var env = new SyncOperationEnvelope
        {
            ClientOperationId = opId,
            UserId = Auth.Uid!,
            OperationType = SyncOperationType.UpdateCalendar,
            ClientTimestampUtc = DateTime.UtcNow,
            Payload = JsonSerializer.SerializeToElement(dto, JsonOpts)
        };

        await OfflineWrite.EnqueueAsync(env);

        if (Network.IsOnline)
        {
            await AutoSync.TrySyncSoonAsync(async () =>
            {
                await SyncRunner.RunOnceAsync();
                await RefreshNowAsync(force: true);
                RefreshDayModalStateFromCurrentData();
            });
        }
        else
        {
            InlineInfo = Loc.GetOr("Page_Calendar_UpdateCalendar_QueuedOffline", "Changes queued offline. They will sync when you are back online.");
        }
    }

    private async Task OnDeleteCalendarAsync(CalendarDeleteRequest req)
    {
        InlineInfo = null;

        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        if (req is null || string.IsNullOrWhiteSpace(req.SourceCalendarId))
            return;

        var source = CalendarState.Current?.My?.Calendars?.FirstOrDefault(c => c.CalendarId == req.SourceCalendarId);
        if (source?.IsPrimary == true)
        {
            InlineInfo = Loc.GetOr("Page_Calendar_PrimaryCannotDelete", "The primary (Contista) calendar cannot be deleted.");
            return;
        }

        var mode = string.IsNullOrWhiteSpace(req.Mode) ? "move" : req.Mode;
        if (string.Equals(mode, "move", StringComparison.OrdinalIgnoreCase) &&
            string.IsNullOrWhiteSpace(req.TargetCalendarId))
        {
            InlineInfo = Loc.GetOr("Page_Calendar_DeleteCalendar_MoveRequiresTarget",
                "To move events you must select a target calendar.");
            return;
        }

        CalendarState.HideCalendar(req.SourceCalendarId);

        SelectedCalendarIds.Remove(req.SourceCalendarId);
        VisibleCalendarIds.Remove(req.SourceCalendarId);

        EnsureAtLeastOneVisible();

        var opId = Guid.NewGuid().ToString("N");

        var payload = new DeleteCalendarWithMoveOperationDto
        {
            SourceCalendarId = req.SourceCalendarId,
            Mode = mode,
            TargetCalendarId = string.Equals(mode, "move", StringComparison.OrdinalIgnoreCase) ? req.TargetCalendarId : null,
            SetHasConflictOnMovedEvents = true
        };

        var env = new SyncOperationEnvelope
        {
            ClientOperationId = opId,
            UserId = Auth.Uid!,
            OperationType = SyncOperationType.DeleteCalendarWithMove,
            ClientTimestampUtc = DateTime.UtcNow,
            Payload = JsonSerializer.SerializeToElement(payload, JsonOpts)
        };

        await OfflineWrite.EnqueueAsync(env);

        IsManageCalendarOpen = false;

        if (Network.IsOnline)
        {
            await AutoSync.TrySyncSoonAsync(async () =>
            {
                await SyncRunner.RunOnceAsync();
                await RefreshNowAsync(force: true);
                RefreshDayModalStateFromCurrentData();
            });
        }
        else
        {
            InlineInfo = Loc.GetOr("Page_Calendar_DeleteCalendar_QueuedOffline",
                "Calendar deletion queued offline. It will sync when you are back online.");

            await RefreshNowAsync(force: true);
            RefreshDayModalStateFromCurrentData();
        }
    }

    private string? GetCalendarName(string? calendarId)
    {
        if (string.IsNullOrWhiteSpace(calendarId)) return null;
        return CalendarState.Current?.My?.Calendars?.FirstOrDefault(c => c.CalendarId == calendarId)?.Name;
    }

    private bool ViewerCanSeeDetailsForCalendar(string? calendarId)
    {
        if (string.IsNullOrWhiteSpace(calendarId)) return false;

        var myUid = Auth?.Uid ?? "";
        if (string.IsNullOrWhiteSpace(myUid)) return false;

        var cal = CalendarState.Current?.My?.Calendars?.FirstOrDefault(c =>
            string.Equals(c.CalendarId, calendarId, StringComparison.Ordinal));

        if (cal is not null && string.Equals(cal.OwnerUserId, myUid, StringComparison.Ordinal))
            return true;

        var row = CalendarState.Current?.My?.MemberRows?.FirstOrDefault(r =>
            string.Equals(r.CalendarId, calendarId, StringComparison.Ordinal) &&
            string.Equals(r.UserId, myUid, StringComparison.Ordinal));

        return row?.Membership?.CanSeeDetails == true;
    }

    private string CurrentUserId => Auth?.Uid ?? "";

    private CalendarVisibility EffectiveVisibilityForViewer(CalendarEventDto ev, string viewerId)
    {
        if (ev is null) return CalendarVisibility.Private;

        var isCreator = !string.IsNullOrWhiteSpace(viewerId)
                        && !string.IsNullOrWhiteSpace(ev.CreatedById)
                        && string.Equals(ev.CreatedById, viewerId, StringComparison.Ordinal);

        if (ev.Visibility == CalendarVisibility.Private)
            return isCreator ? CalendarVisibility.Details : CalendarVisibility.Private;

        if (ev.Visibility == CalendarVisibility.BusyOnly)
            return isCreator ? CalendarVisibility.Details : CalendarVisibility.BusyOnly;

        return CalendarVisibility.Details;
    }

    private CalendarAvailability BlockingAvailabilityForViewer(CalendarEventDto ev, string viewerId)
    {
        var eff = EffectiveVisibilityForViewer(ev, viewerId);
        return CalendarAvailabilityPolicy.GetDisplayAvailability(ev, eff);
    }

    private static bool Overlaps(DateTime aStart, DateTime aEnd, DateTime bStart, DateTime bEnd)
        => aStart < bEnd && aEnd > bStart;

    private List<CalendarEventDto> FindBlockingConflicts(CalendarEventDto candidate, string viewerId, IEnumerable<CalendarEventDto>? all)
    {
        if (candidate is null) return new();
        if (all is null) return new();

        var candStart = DateTimes.ToLocalFromUtc(candidate.StartUtc);
        var candEnd = DateTimes.ToLocalFromUtc(candidate.EndUtc);

        if (candidate.IsAllDay)
        {
            candStart = candStart.Date;
            candEnd = candStart.AddDays(1);
        }

        var res = new List<CalendarEventDto>();

        foreach (var ev in all)
        {
            if (ev is null) continue;
            if (string.IsNullOrWhiteSpace(ev.CalendarId) || string.IsNullOrWhiteSpace(candidate.CalendarId)) continue;
            if (!string.Equals(ev.CalendarId, candidate.CalendarId, StringComparison.Ordinal)) continue;

            if (!string.IsNullOrWhiteSpace(candidate.EventId) &&
                !string.IsNullOrWhiteSpace(ev.EventId) &&
                string.Equals(ev.EventId, candidate.EventId, StringComparison.Ordinal))
                continue;

            var evAvail = BlockingAvailabilityForViewer(ev, viewerId);
            if (!CalendarAvailabilityPolicy.IsBlocking(evAvail))
                continue;

            var evStart = DateTimes.ToLocalFromUtc(ev.StartUtc);
            var evEnd = DateTimes.ToLocalFromUtc(ev.EndUtc);

            if (ev.IsAllDay)
            {
                evStart = evStart.Date;
                evEnd = evStart.AddDays(1);
            }

            if (Overlaps(candStart, candEnd, evStart, evEnd))
                res.Add(ev);
        }

        return res.OrderBy(e => e.StartUtc).ToList();
    }

    private string? ResolveUserName(string? userId)
    {
        if (string.IsNullOrWhiteSpace(userId))
            return null;

        return Users.TryGetName(userId);
    }

    private string ConflictSummaryText(CalendarEventDto candidate, List<CalendarEventDto> conflicts, string viewerId)
    {
        if (conflicts is null || conflicts.Count == 0) return "";

        string Describe(CalendarEventDto ev)
        {
            var eff = EffectiveVisibilityForViewer(ev, viewerId);

            var start = DateTimes.ToLocalFromUtc(ev.StartUtc);
            var end = DateTimes.ToLocalFromUtc(ev.EndUtc);

            var time = ev.IsAllDay
                ? Loc.GetOr("Common_Actions_AllDay", "All day")
                : $"{start:HH:mm}-{end:HH:mm}";

            if (eff == CalendarVisibility.Private)
                return $"{time} · {Loc.GetOr("Page_Calendar_Availability_Busy", "Busy")}";

            if (eff == CalendarVisibility.BusyOnly)
                return $"{time} · {Loc.GetOr("Page_Calendar_Availability_Busy", "Busy")}";

            var title = string.IsNullOrWhiteSpace(ev.Title)
                ? Loc.GetOr("Common_Actions_Untitled", "Untitled")
                : ev.Title;

            return $"{time} · {title}";
        }

        var lines = conflicts.Take(2).Select(Describe).ToList();
        var more = conflicts.Count - lines.Count;

        var header = Loc.GetOr("Page_Calendar_Conflict_Header", "Time conflict with:");
        var body = string.Join(" | ", lines);
        if (more > 0) body += $" | +{more}";

        var candLabel = CalendarAvailabilityPolicy.Label(Loc, candidate.Availability);
        var prefix = $"{Loc.GetOr("Common_Availability", "Availability")}: {candLabel}. ";

        return prefix + header + " " + body;
    }
}