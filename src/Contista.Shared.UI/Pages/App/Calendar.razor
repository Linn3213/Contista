    private static bool IsSyntheticOccurrence(CalendarEventDto e)
    {
        if (e is null) return false;
        if (string.IsNullOrWhiteSpace(e.OccurrenceOverrideSeriesId)) return false;
        if (!e.OriginalStartUtc.HasValue) return false;
        if (e.IsOccurrenceOverride || e.IsOccurrenceCancelled) return false;
        if (string.IsNullOrWhiteSpace(e.EventId)) return false;
        if (!e.EventId.Contains(':')) return false;

        return true;
    }

