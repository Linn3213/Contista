    private List<CalendarDto> GetShareableCalendars(List<CalendarDto> cals)
    {
        var myUid = Auth?.Uid ?? "";
        var memberRows = CalendarState.Current?.My?.MemberRows ?? new List<CalendarMemberRowDto>();

        bool CanShareCal(CalendarDto cal)
        {
            if (cal is null || string.IsNullOrWhiteSpace(cal.CalendarId)) return false;
            if (string.Equals(cal.OwnerUserId, myUid, StringComparison.Ordinal)) return true;

            var row = memberRows.FirstOrDefault(r =>
                string.Equals(r.CalendarId, cal.CalendarId, StringComparison.Ordinal) &&
                string.Equals(r.UserId, myUid, StringComparison.Ordinal));

            return row?.Membership?.CanShare == true;
        }

        return cals.Where(CanShareCal).ToList();
    }

    private List<CalendarDto> GetEditableCalendars(List<CalendarDto> cals)
    {
        var myUid = Auth?.Uid ?? "";
        var memberRows = CalendarState.Current?.My?.MemberRows ?? new List<CalendarMemberRowDto>();

        bool CanEditCal(CalendarDto cal)
        {
            if (cal is null || string.IsNullOrWhiteSpace(cal.CalendarId))
                return false;

            if (string.Equals(cal.OwnerUserId, myUid, StringComparison.Ordinal))
                return true;

            var row = memberRows.FirstOrDefault(r =>
                string.Equals(r.CalendarId, cal.CalendarId, StringComparison.Ordinal) &&
                string.Equals(r.UserId, myUid, StringComparison.Ordinal));

            return row?.Membership?.CanEdit == true;
        }

        return cals.Where(CanEditCal).ToList();
    }

