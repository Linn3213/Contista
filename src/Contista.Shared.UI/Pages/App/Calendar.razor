    private static bool GetChecked(ChangeEventArgs e)
    {
        return e?.Value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var b) => b,
            _ => false
        };
    }

    private async Task ToggleCalendar(string calendarId, ChangeEventArgs e)
    {
        var isChecked = GetChecked(e);

        var primaryId = GetPrimaryCalendarId();
        var isPrimary = !string.IsNullOrWhiteSpace(primaryId) &&
                        string.Equals(calendarId, primaryId, StringComparison.Ordinal);

        _userHasChangedVisibleSelection = true;
        _hasAppliedInitialCalendarSelection = true;

        var beforeVisible = new HashSet<string>(VisibleCalendarIds, StringComparer.Ordinal);

        if (isChecked) VisibleCalendarIds.Add(calendarId);
        else VisibleCalendarIds.Remove(calendarId);

        EnsureAtLeastOneVisible(fallbackId: calendarId);

        var persistedChanged = false;

        if (!isPrimary)
        {
            if (isChecked) persistedChanged = SelectedCalendarIds.Add(calendarId);
            else persistedChanged = SelectedCalendarIds.Remove(calendarId);

            if (!string.IsNullOrWhiteSpace(primaryId) && !SelectedCalendarIds.Contains(primaryId!))
            {
                SelectedCalendarIds.Add(primaryId!);
                persistedChanged = true;
            }
        }

        var visibleChanged = !beforeVisible.SetEquals(VisibleCalendarIds);

        if (!visibleChanged && !persistedChanged)
        {
            _lastToggleTriggeredGuard = false;
            return;
        }

        InlineInfo = _lastToggleTriggeredGuard
            ? Loc.GetOr("Page_Calendar_Filter_Guard", "At least one calendar must be visible. Showing the primary calendar.")
            : null;

        if (persistedChanged)
            await SaveCalendarSelectionAsync();

        if (visibleChanged)
        {
            await RefreshNowAsync(force: true);
            RefreshDayModalStateFromCurrentData();
        }

        await InvokeAsync(StateHasChanged);
    }

