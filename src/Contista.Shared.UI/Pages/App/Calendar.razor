@* Calendar.razor *@
@page "/app/calendar"
@inherits AppPageBase
@implements IDisposable

@using System.Text.Json
@using Contista.Shared.Core.DTO.Calendar
@using Contista.Shared.Core.Models.Calendar
@using Contista.Shared.Core.Offline.Interfaces
@using Contista.Shared.Core.Offline.Models
@using Contista.Shared.Core.Offline.Models.Calendar
@using Contista.Shared.Core.Offline.Models.Operations
@using Contista.Shared.Core.Interfaces.SyncDebug
@using Contista.Shared.Core.Interfaces.Auth
@using Contista.Shared.Core.Interfaces.Calendar
@using Contista.Shared.Core.Models.Auth
@using Contista.Shared.UI.Components.Calendar
@using Contista.Shared.UI.Components.Modals
@using Contista.Shared.UI.Components.Modals.Calendar
@using Contista.Shared.UI.Utils

@inject ICalendarState CalendarState

@inject IOfflineWriteService OfflineWrite
@inject ISyncRunner SyncRunner
@inject INetworkStatus Network
@inject IAutoSyncDispatcher AutoSync
@inject IFeatureAccessService Features
@inject IReminderScheduler ReminderScheduler

@{
    var allCals = CalendarState.Current?.My?.Calendars?.ToList() ?? new List<CalendarDto>();
    var cals = allCals.Where(c => c is not null && !_hiddenCalendarIds.Contains(c.CalendarId)).ToList();

    var hasMany = cals.Count > 1;
    var primary = allCals.FirstOrDefault(x => x.IsPrimary);
}

<div class="card cal-card">
    <div class="card-body">

        <div class="cal-header">
            <div class="cal-headerLeft">
                <h2 class="cal-title">@GetViewTitle()</h2>
                <div class="cal-subtitle">@Loc.GetOr("Page_Calendar_Subtitle", "Plan, track and create events for your content.")</div>
            </div>

            <div class="cal-toolbar">
                <div class="cal-headerCenter">
                    <div class="cal-viewToggle" role="group" aria-label="@Loc.GetOr("Page_Calendar_ViewToggle_Aria", "Calendar view")">
                        <button type="button"
                                class="cal-toggleBtn @(View == CalendarViewMode.Month ? "is-active" : "")"
                                @onclick="() => SetViewAsync(CalendarViewMode.Month)">
                            @Loc.GetOr("Page_Calendar_View_Month_Button", "Month")
                        </button>
                        <button type="button"
                                class="cal-toggleBtn @(View == CalendarViewMode.Week ? "is-active" : "")"
                                @onclick="() => SetViewAsync(CalendarViewMode.Week)">
                            @Loc.GetOr("Page_Calendar_View_Week_Button", "Week")
                        </button>
                        <button type="button"
                                class="cal-toggleBtn @(View == CalendarViewMode.Agenda ? "is-active" : "")"
                                @onclick="() => SetViewAsync(CalendarViewMode.Agenda)">
                            @Loc.GetOr("Page_Calendar_View_Agenda_Button", "Agenda")
                        </button>
                    </div>
                </div>

                <div class="cal-headerRight">
                    @if (hasMany)
                    {
                        <div class="dropdown">
                            <button class="btn btn-sm btn-ghost dropdown-toggle cal-calendarFilterBtn"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                <span class="text-truncate">@GetSelectedCalendarsLabel(cals)</span>
                            </button>

                            <div class="dropdown-menu p-2 cal-calendarFilterMenu">
                                @foreach (var cal in cals)
                                {
                                    var checkedNow = VisibleCalendarIds.Contains(cal.CalendarId);

                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="cal_@cal.CalendarId"
                                               checked="@checkedNow"
                                               @onchange="(e) => ToggleCalendar(cal.CalendarId, e)" />

                                        <label class="form-check-label" for="cal_@cal.CalendarId">
                                            @cal.Name
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <button type="button"
                            class="btn btn-sm btn-ghost cal-desktopAction"
                            disabled="@(!CanCreateExtraCalendar)"
                            title="@Loc.GetOr("Page_Calendar_CreateCalendar_Button", "New calendar")"
                            @onclick="OpenCreateCalendar">
                        <i class="bi bi-calendar-plus"></i>
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-ghost cal-desktopAction"
                            title="@Loc.GetOr("Page_Calendar_Manage_Tooltip", "Manage calendars")"
                            aria-label="@Loc.GetOr("Page_Calendar_Manage_Tooltip", "Manage calendars")"
                            data-testid="calendar-open-manage"
                            @onclick="OpenManageCalendars">
                        <i class="bi bi-gear"></i>
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-ghost cal-desktopAction"
                            disabled="@(!CanUseShareAction(cals))"
                            title="@GetShareButtonTooltip(cals)"
                            aria-label="@Loc.GetOr("Page_Calendar_Share_Tooltip", "Share calendar")"
                            data-testid="calendar-open-share"
                            @onclick="OpenShareModal">
                        <i class="bi bi-person-plus"></i>
                    </button>

                    <div class="dropdown cal-mobileActions">
                        <button class="btn btn-sm btn-ghost dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                aria-label="@Loc.GetOr("Common_Actions_More", "More actions")">
                            <i class="bi bi-three-dots"></i>
                        </button>

                        <div class="dropdown-menu dropdown-menu-end p-1">
                            <button type="button"
                                    class="dropdown-item"
                                    disabled="@(!CanCreateExtraCalendar)"
                                    @onclick="OpenCreateCalendar">
                                @Loc.GetOr("Page_Calendar_CreateCalendar_Button", "New calendar")
                            </button>
                            <button type="button"
                                    class="dropdown-item"
                                    data-testid="calendar-open-manage-mobile"
                                    @onclick="OpenManageCalendars">
                                @Loc.GetOr("Page_Calendar_Manage_Tooltip", "Manage calendars")
                            </button>
                            <button type="button"
                                    class="dropdown-item"
                                    data-testid="calendar-open-share-mobile"
                                    disabled="@(!CanUseShareAction(cals))"
                                    @onclick="OpenShareModal">
                                @Loc.GetOr("Page_Calendar_Share_Tooltip", "Share calendar")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="cal-sep" aria-hidden="true"></div>

        @if (!Auth.IsLoggedIn)
        {
            <div class="cal-statusPanel cal-statusPanel-neutral" role="status">
                @Loc.GetOr("Common_Auth_NotLoggedIn", "Not logged in.")
            </div>
        }
        else
        {
            var data = CalendarState.Current;
            var hasData = data is not null;

            if (!hasData && CalendarState.IsLoading)
            {
                <div class="cal-statusPanel cal-statusPanel-neutral" role="status" aria-live="polite">
                    @Loc.GetOr("Page_Calendar_Loading", "Loading calendar…")
                </div>
            }
            else if (!hasData && !string.IsNullOrWhiteSpace(CalendarState.LastError))
            {
                <div class="alert alert-danger my-2 cal-statusPanel" role="alert">
                    @Loc.GetOr("Page_Calendar_Error_Generic", "Could not load the calendar.")
                    @if (ShowTechnicalErrors)
                    {
                        <div class="small opacity-75">@CalendarState.LastError</div>
                    }
                </div>
            }
            else
            {
                var events = (data?.Events ?? new List<CalendarEventDto>())
                .Where(e => !string.IsNullOrWhiteSpace(e.CalendarId) && VisibleCalendarIds.Contains(e.CalendarId))
                .ToList();

                <div class="cal-viewWrap">
                    @if (View == CalendarViewMode.Month)
                    {
                        <CalendarMonthView CurrentMonth="@CurrentMonth"
                                           Events="@events"
                                           OnChecklistToggled="OnChecklistToggledAsync"
                                           OnDayClicked="OnDayClicked"
                                           OnAddClicked="OnAddClicked"
                                           OnMonthChanged="OnMonthChangedAsync"
                                           CalendarIdToHex="@GetCalendarHex"
                                           CalendarIdToName="@GetCalendarName"
                                           CurrentUserId="@CurrentUserId"
                                           CanSeeDetailsForCalendar="@ViewerCanSeeDetailsForCalendar"
                                           OnEditRequested="@(ev => { OpenEdit(ev); return Task.CompletedTask; })"
                                           OnEditSeriesRequested="OpenEditSeries"
                                           OnDeleteRequested="ConfirmDeleteFromListAsync" />
                    }
                    else if (View == CalendarViewMode.Week)
                    {
                        <CalendarWeekView WeekStart="@WeekStart"
                                          Events="@events"
                                          CalendarIdToHex="@GetCalendarHex"
                                          OnTimeSlotClicked="OnTimeSlotClicked"
                                          OnAddClicked="OnAddClicked"
                                          OnWeekChanged="OnWeekChangedAsync"
                                          OnDayHeaderClicked="@(day => { OpenDayModal(day); return Task.CompletedTask; })"
                                          OnEventClicked="@(ev => { OpenEventModal(ev); return Task.CompletedTask; })"
                                          CurrentUserId="@CurrentUserId" />
                    }
                    else
                    {
                        <CalendarAgendaView FromDate="@AnchorLocal"
                                            DaysAhead="7"
                                            Events="@events"
                                            OnRangeChanged="OnAgendaRangeChangedAsync"
                                            OnDayHeaderClicked="@(day => { OpenDayModal(day); return Task.CompletedTask; })"
                                            OnDayBodyClicked="OnAddClicked"
                                            OnAddClicked="OnAddClicked"
                                            OnEventClicked="@(ev => { OpenEventModal(ev); return Task.CompletedTask; })"
                                            CurrentUserId="@CurrentUserId"
                                            CalendarIdToHex="@GetCalendarHex" />
                    }

                    @if (CalendarState.IsLoading)
                    {
                        <div class="cal-loadingOverlay" aria-hidden="true">
                            <div class="cal-loadingChip">
                                @Loc.GetOr("Page_Calendar_Loading", "Loading calendar…")
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="cal-sep" aria-hidden="true"></div>
        }

        @* Day modal stays mounted/open even when edit modal is opened *@
        <CalendarDayEventsModal @key="_dayModalRenderKey"
                                IsOpen="@_isDayModalOpen"
                                IsOpenChanged="OnDayModalOpenChanged"
                                DateLocal="@_dayModalDateLocal"
                                Events="@(_dayModalEventId is null
                                                                            ? GetVisibleEventsForDay(_dayModalDateLocal)
                                                                            : new List<CalendarEventDto>())"
                                SingleEvent="@CurrentDayModalSingleEvent"
                                FocusEventId="@_dayModalFocusEventId"
                                RefreshKey="@_dayModalRefreshKey"
                                CurrentUserId="@CurrentUserId"
                                CalendarIdToHex="@GetCalendarHex"
                                CalendarIdToName="@GetCalendarName"
                                UserIdToName="@ResolveUserName"
                                OnAddRequested="OnAddClicked"
                                OnEditRequested="@(ev => { OpenEdit(ev); return Task.CompletedTask; })"
                                OnEditSeriesRequested="OpenEditSeries"
                                OnDeleteRequested="ConfirmDeleteFromListAsync"
                                OnChecklistToggled="OnChecklistToggledAsync" />

        @if (IsQuickAddOpen)
        {
            <CalendarEventManageModal IsOpen="@IsQuickAddOpen"
                                      IsOpenChanged="OnQuickAddOpenChanged"
                                      DefaultStartLocal="@QuickAddDefaultStartLocal"
                                      DefaultEndLocal="@QuickAddDefaultEndLocal"
                                      Calendars="GetEditableCalendars(cals)"
                                      DefaultCalendarId="@GetDefaultCreateCalendarIdForModal()"
                                      CalendarIdToHex="@GetCalendarHex"
                                      OnSave="OnQuickAddSaveAsync" />
        }

        @if (IsEditModalOpen && EditModel is not null)
        {
            <CalendarEventManageModal IsOpen="@IsEditModalOpen"
                                      IsOpenChanged="OnEditOpenChanged"
                                      ExistingEvent="EditModel"
                                      Calendars="GetEditableCalendars(cals)"
                                      OnSave="OnEditSaveAsync"
                                      OnEditSeries="OpenEditSeries"
                                      CalendarIdToHex="@GetCalendarHex"
                                      OnDelete="OnEditDeleteAsync" />
        }

        @if (IsCreateCalendarOpen)
        {
            <CalendarCreateModal IsOpen="@IsCreateCalendarOpen"
                                 IsOpenChanged="OnCreateCalendarOpenChanged"
                                 OnSave="OnCreateCalendarSaveAsync" />
        }

        @if (IsManageCalendarOpen)
        {
            <CalendarManageModal IsOpen="@IsManageCalendarOpen"
                                 IsOpenChanged="OnManageCalendarOpenChanged"
                                 UserId="@UserState.Current.UserId"
                                 Calendars="cals"
                                 ManageableCalendarIds="@GetManageableCalendarIds(cals)"
                                 OnSave="OnUpdateCalendarSaveAsync"
                                 OnDeleteCalendarRequested="OnDeleteCalendarAsync" />
        }

        @if (IsShareModalOpen)
        {
            <CalendarShareModal IsOpen="@IsShareModalOpen"
                                IsOpenChanged="OnShareOpenChanged"
                                ShareableCalendars="@GetShareableCalendars(cals)"
                                OnInviteSent="OnInviteSentAsync" />
        }

        <ConfirmModal @ref="_inviteSentConfirm"
                      ModalOptions="@(new { backdrop = false, keyboard = false })"
                      Variant="info"
                      Title="@Loc.GetOr("Page_CalendarShareModal_Invite_Sent_Title", "Invitation sent")"
                      ConfirmText="@Loc.GetOr("Common_Actions_Ok", "OK")"
                      CancelText="@Loc.GetOr("Common_Actions_Close", "Close")"
                      OnConfirm="OnInviteConfirmAsync">
            <MessageContent>
                <div>@_inviteSentMessage</div>
            </MessageContent>
        </ConfirmModal>

    </div>
</div>

@code {
    [Inject] public IUserDirectoryState Users { get; set; } = default!;
    private static readonly JsonSerializerOptions JsonOpts = new(JsonSerializerDefaults.Web);

    private CalendarViewMode View = CalendarViewMode.Month;
    private bool IsShareModalOpen;
    private bool CanUseCalendarShareFeature;
    private ConfirmModal? _inviteSentConfirm;
    private string _inviteSentMessage = "";

    private DateTime TodayLocal => DateTime.Now.Date;
    private DateTime AnchorLocal = DateTime.Now.Date;

    private DateTime CurrentMonth => new DateTime(AnchorLocal.Year, AnchorLocal.Month, 1);

    private DateTime WeekStart
    {
        get
        {
            var d = AnchorLocal.Date;
            var diff = (7 + (d.DayOfWeek - DayOfWeek.Monday)) % 7;
            return d.AddDays(-diff);
        }
    }

    private readonly HashSet<string> _hiddenCalendarIds = new(StringComparer.Ordinal);

    private static bool ShowTechnicalErrors
    {
        get
        {
#if DEBUG
            return true;
#else
            return false;
#endif
        }
    }

    private bool IsQuickAddOpen;
    private DateTime QuickAddDefaultStartLocal;
    private DateTime QuickAddDefaultEndLocal;

    private bool IsEditModalOpen;
    private CalendarEventDto? EditModel;

    private string? InlineInfo;

    private int ExtraCalendarsCount =>
        CalendarState.Current?.My?.Calendars?.Count(c => c is not null && !c.IsPrimary) ?? 0;

    private string? UserMembershipKey => UserState.Current?.MembershipId;

    private int MaxExtraCalendars => MembershipRules.GetMaxExtraCalendars(CommonState.Current, UserMembershipKey);
    private bool CanCreateExtraCalendar => ExtraCalendarsCount < MaxExtraCalendars;

    private HashSet<string> SelectedCalendarIds = new(StringComparer.Ordinal);
    private HashSet<string> VisibleCalendarIds = new(StringComparer.Ordinal);

    private bool _hasAppliedInitialCalendarSelection;
    private bool _userHasChangedVisibleSelection;
    private bool _lastToggleTriggeredGuard;

    private bool _isDayModalOpen;
    private DateTime _dayModalDateLocal;
    private string? _dayModalFocusEventId;

    // Stable modal state: store ids, never stale event object references
    private string? _dayModalEventId;
    private int _dayModalRefreshKey;
    private string _dayModalRenderKey => $"{_dayModalDateLocal:yyyyMMdd}:{_dayModalEventId}:{_dayModalFocusEventId}:{_dayModalRefreshKey}";

    private CalendarEventDto? CurrentDayModalSingleEvent
        => string.IsNullOrWhiteSpace(_dayModalEventId)
            ? null
            : VisibleEventsForUi.FirstOrDefault(e => string.Equals(e.EventId, _dayModalEventId, StringComparison.Ordinal));

    private List<CalendarEventDto> VisibleEventsForUi =>
        (CalendarState.Current?.Events ?? new List<CalendarEventDto>())
            .Where(e => !string.IsNullOrWhiteSpace(e.CalendarId) && VisibleCalendarIds.Contains(e.CalendarId))
            .ToList();

    private List<CalendarEventDto> GetVisibleEventsForDay(DateTime dayLocal)
    {
        var start = dayLocal.Date;
        var end = start.AddDays(1);

        return VisibleEventsForUi
            .Where(e =>
                DateTimes.ToLocalFromUtc(e.StartUtc) < end &&
                DateTimes.ToLocalFromUtc(e.EndUtc) > start)
            .OrderBy(e => e.StartUtc)
            .ToList();
    }

    private string? GetPrimaryCalendarId()
        => CalendarState.Current?.My?.Calendars?.FirstOrDefault(c => c.IsPrimary)?.CalendarId;

    private bool IsCreateCalendarOpen;
    private bool IsManageCalendarOpen;

    protected override async Task OnInitializedAsync()
    {
        CalendarState.Changed += OnCalendarStateChanged;

        await CommonState.EnsureLoadedAsync();
        CanUseCalendarShareFeature = await Features.CanAsync(FeatureKey.CalendarShare, CancellationToken.None);

        if (Auth.IsLoggedIn && !string.IsNullOrWhiteSpace(Auth.Uid))
        {
            await UserState.EnsureLoadedAsync(Auth.Uid!, CancellationToken.None);

            var cals = CalendarState.Current?.My?.Calendars?.ToList() ?? new List<CalendarDto>();
            var primaryId = cals.FirstOrDefault(x => x.IsPrimary)?.CalendarId;

            var validCalendarIds = cals
                .Where(x => !string.IsNullOrWhiteSpace(x.CalendarId))
                .Select(x => x.CalendarId)
                .ToHashSet(StringComparer.Ordinal);

            var fromSettings = CalendarState.Current?.Settings?.SelectedCalendarIds?
                .Where(x => !string.IsNullOrWhiteSpace(x) && validCalendarIds.Contains(x))
                .ToHashSet(StringComparer.Ordinal)
                ?? new HashSet<string>(StringComparer.Ordinal);

            if (fromSettings.Count > 0)
                SelectedCalendarIds = new HashSet<string>(fromSettings, StringComparer.Ordinal);
            else
                SelectedCalendarIds = new HashSet<string>(StringComparer.Ordinal);

            if (SelectedCalendarIds.Count == 0 && !string.IsNullOrWhiteSpace(primaryId))
                SelectedCalendarIds.Add(primaryId!);

            if (SelectedCalendarIds.Count == 0 && cals.Count > 0)
                SelectedCalendarIds.Add(cals[0].CalendarId);

            if (!string.IsNullOrWhiteSpace(primaryId))
                SelectedCalendarIds.Add(primaryId!);

            VisibleCalendarIds = new HashSet<string>(SelectedCalendarIds, StringComparer.Ordinal);

            _hasAppliedInitialCalendarSelection = SelectedCalendarIds.Count > 0;

            await RefreshNowAsync(force: true);
            EnsureInitialCalendarSelection();
        }
    }

    public void Dispose()
    {
        CalendarState.Changed -= OnCalendarStateChanged;
    }

    private void OnCalendarStateChanged()
    {
        EnsureInitialCalendarSelection();
        RefreshDayModalStateFromCurrentData();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OpenDayModal(DateTime dayLocal)
    {
        IsQuickAddOpen = false;
        IsEditModalOpen = false;

        _dayModalEventId = null;
        _dayModalDateLocal = dayLocal.Date;
        _dayModalFocusEventId = null;
        _isDayModalOpen = true;
        TouchDayModal();
    }

    private void OpenEventModal(CalendarEventDto ev)
    {
        IsQuickAddOpen = false;
        IsEditModalOpen = false;

        _dayModalEventId = ev.EventId;
        _dayModalDateLocal = DateTimes.ToLocalFromUtc(ev.StartUtc).Date;
        _dayModalFocusEventId = ev.EventId;
        _isDayModalOpen = true;
        TouchDayModal();
    }

    private void TouchDayModal()
    {
        _dayModalRefreshKey++;
    }

    private void RefreshDayModalStateFromCurrentData()
    {
        if (!_isDayModalOpen)
            return;

        if (!string.IsNullOrWhiteSpace(_dayModalEventId))
        {
            var current = VisibleEventsForUi.FirstOrDefault(e =>
                string.Equals(e.EventId, _dayModalEventId, StringComparison.Ordinal));

            if (current is not null)
            {
                _dayModalDateLocal = DateTimes.ToLocalFromUtc(current.StartUtc).Date;
                _dayModalFocusEventId = current.EventId;
            }
            else
            {
                // If the focused single event disappeared (deleted/moved), fall back to day list.
                _dayModalEventId = null;
                _dayModalFocusEventId = null;
            }
        }

        TouchDayModal();
    }

    private void EnsureAtLeastOneVisible(string? fallbackId = null)
    {
        _lastToggleTriggeredGuard = false;

        if (VisibleCalendarIds.Count > 0)
            return;

        var primaryId = GetPrimaryCalendarId();
        if (!string.IsNullOrWhiteSpace(primaryId))
        {
            VisibleCalendarIds.Add(primaryId!);
            _lastToggleTriggeredGuard = true;
            return;
        }

        if (!string.IsNullOrWhiteSpace(fallbackId))
        {
            VisibleCalendarIds.Add(fallbackId!);
            _lastToggleTriggeredGuard = true;
            return;
        }

        var any = CalendarState.Current?.My?.Calendars?
            .FirstOrDefault(c => !string.IsNullOrWhiteSpace(c.CalendarId))?.CalendarId;

        if (!string.IsNullOrWhiteSpace(any))
        {
            VisibleCalendarIds.Add(any!);
            _lastToggleTriggeredGuard = true;
        }
    }

    private void EnsureInitialCalendarSelection()
    {
        if (!_userHasChangedVisibleSelection)
        {
            if (SelectedCalendarIds.Count > 0)
                VisibleCalendarIds = new HashSet<string>(SelectedCalendarIds, StringComparer.Ordinal);
            else
                VisibleCalendarIds.Clear();

            EnsureAtLeastOneVisible();
        }

        if (_hasAppliedInitialCalendarSelection)
            return;

        var cals = CalendarState.Current?.My?.Calendars?
            .Where(c => c is not null && !string.IsNullOrWhiteSpace(c.CalendarId))
            .ToList() ?? new List<CalendarDto>();

        if (cals.Count == 0)
            return;

        var fromSettings = CalendarState.Current?.Settings?.SelectedCalendarIds?
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .ToHashSet(StringComparer.Ordinal)
            ?? new HashSet<string>(StringComparer.Ordinal);

        if (fromSettings.Count > 0)
        {
            SelectedCalendarIds = cals
                .Where(c => fromSettings.Contains(c.CalendarId))
                .Select(c => c.CalendarId)
                .ToHashSet(StringComparer.Ordinal);
        }

        if (SelectedCalendarIds.Count == 0)
        {
            var primaryId = cals.FirstOrDefault(c => c.IsPrimary)?.CalendarId;
            if (!string.IsNullOrWhiteSpace(primaryId))
                SelectedCalendarIds.Add(primaryId!);
        }

        if (SelectedCalendarIds.Count == 0 && cals.Count > 0)
            SelectedCalendarIds.Add(cals[0].CalendarId);

        var p = cals.FirstOrDefault(c => c.IsPrimary)?.CalendarId;
        if (!string.IsNullOrWhiteSpace(p))
            SelectedCalendarIds.Add(p!);

        _hasAppliedInitialCalendarSelection = SelectedCalendarIds.Count > 0;

        if (!_userHasChangedVisibleSelection)
        {
            VisibleCalendarIds = new HashSet<string>(SelectedCalendarIds, StringComparer.Ordinal);
            EnsureAtLeastOneVisible();
        }

        if (_hasAppliedInitialCalendarSelection && Auth.IsLoggedIn && !string.IsNullOrWhiteSpace(Auth.Uid))
            _ = RefreshNowAsync(force: true);
    }

    private void OpenManageCalendars()
    {
        InlineInfo = null;
        IsManageCalendarOpen = true;
    }

    private void OpenShareModal()
    {
        if (!CanUseShareAction(CalendarState.Current?.My?.Calendars?.ToList() ?? new List<CalendarDto>()))
            return;

        InlineInfo = null;
        IsShareModalOpen = true;
    }

    private bool CanUseShareAction(List<CalendarDto> cals)
    {
        if (!Network.IsOnline)
            return false;

        if (!CanUseCalendarShareFeature)
            return false;

        return GetShareableCalendars(cals).Count > 0;
    }

    private string GetShareButtonTooltip(List<CalendarDto> cals)
    {
        if (!CanUseCalendarShareFeature)
            return Loc.GetOr("Page_Calendar_Share_Disabled_Feature", "Calendar sharing requires a paid membership.");

        if (!Network.IsOnline)
            return Loc.GetOr("Page_Calendar_Share_Disabled_Offline", "You must be online to share calendars.");

        if (GetShareableCalendars(cals).Count == 0)
            return Loc.GetOr("Page_Calendar_Share_Disabled_NoPermission", "You don't have permission to share any calendar.");

        return Loc.GetOr("Page_Calendar_Share_Tooltip", "Share calendar");
    }

    private Task OnShareOpenChanged(bool open)
    {
        IsShareModalOpen = open;
        return Task.CompletedTask;
    }

    private async Task OnInviteSentAsync(string email)
    {
        _inviteSentMessage = string.Format(
            Loc.GetOr("Page_CalendarShareModal_Invite_Sent_WithEmail", "Invite sent to {0} and is now pending."),
            email);

        await RefreshNowAsync(force: true);

        if (_inviteSentConfirm is not null)
            await _inviteSentConfirm.ShowAsync();
    }

    private Task OnInviteConfirmAsync()
        => Task.CompletedTask;

    private Task OnManageCalendarOpenChanged(bool open)
    {
        IsManageCalendarOpen = open;
        return Task.CompletedTask;
    }

    private Task OnDayModalOpenChanged(bool open)
    {
        _isDayModalOpen = open;

        if (!open)
        {
            _dayModalEventId = null;
            _dayModalFocusEventId = null;
            _dayModalDateLocal = default;
            _dayModalRefreshKey = 0;
        }

        return Task.CompletedTask;
    }

    private string GetViewTitle()
        => View switch
        {
            CalendarViewMode.Month => Loc.GetOr("Page_Calendar_View_Month_Title", "Month calendar"),
            CalendarViewMode.Week => Loc.GetOr("Page_Calendar_View_Week_Title", "Week calendar"),
            CalendarViewMode.Agenda => Loc.GetOr("Page_Calendar_View_Agenda_Title", "Agenda calendar"),
            _ => Loc.GetOr("Page_Calendar_Title", "Calendar")
        };

    private async Task SetViewAsync(CalendarViewMode v)
    {
        View = v;

        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        await RefreshNowAsync(force: true);
    }

    private async Task OnMonthChangedAsync(DateTime monthLocal)
    {
        AnchorLocal = new DateTime(monthLocal.Year, monthLocal.Month, 1);

        if (!Auth.IsLoggedIn || string.IsNullOrWhiteSpace(Auth.Uid))
            return;

        await RefreshNowAsync(force: true);
    }

    private async Task OnWeekChangedAsync(DateTime weekStartLocal)
    {
        AnchorLocal = weekStartLocal.Date;

